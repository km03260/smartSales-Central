---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "customApps — suite d'applications mobiles pour digitaliser vos processus terrain : ventes, achats, expéditions, synchronisation de fichiers. Compatible ERP WaveSoft.",
  ogImage = "/og-default.png",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const API_URL = import.meta.env.PUBLIC_API_URL || 'https://api.customapps.fr';

// Analytics Plausible : activé uniquement si PUBLIC_PLAUSIBLE_DOMAIN est défini dans .env
// Respecte la vie privée (pas de cookies, RGPD-compliant, données hébergées en UE)
const PLAUSIBLE_DOMAIN = import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN;
const PLAUSIBLE_SCRIPT = import.meta.env.PUBLIC_PLAUSIBLE_SCRIPT || 'https://plausible.io/js/script.js';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "customApps",
  "url": "https://customapps.fr",
  "email": "contact@customapps.fr",
  "description": description,
};
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#2563eb" />
    <meta name="format-detection" content="telephone=no" />

    <!-- Canonical + langue -->
    <link rel="canonical" href={canonicalURL.href} />
    <link rel="alternate" hreflang="fr" href={canonicalURL.href} />
    <link rel="alternate" hreflang="x-default" href={canonicalURL.href} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:alt" content="customApps — suite d'applications mobiles pour le terrain" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="customApps" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* Pre-paint script : applique le thème avant le premier render pour éviter le FOUC */}
    <script is:inline>
      (function() {
        try {
          const stored = localStorage.getItem('customapps-theme');
          const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          const theme = stored || (systemDark ? 'dark' : 'light');
          if (theme === 'dark') document.documentElement.classList.add('dark');
        } catch (e) {}
      })();
    </script>

    <!-- Fonts : Inter (body) + Instrument Serif (display italique) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    {/* Analytics Plausible (opt-in via env var, privacy-first) */}
    {PLAUSIBLE_DOMAIN && (
      <script defer data-domain={PLAUSIBLE_DOMAIN} src={PLAUSIBLE_SCRIPT}></script>
    )}

    <title>{title}</title>
  </head>
  <body class="bg-white dark:bg-[#0b1220] text-gray-900 dark:text-gray-100 antialiased" style="font-family: 'Inter', system-ui, sans-serif;">
    <!-- Header -->
    <header class="fixed top-0 left-0 right-0 z-50 glass border-b border-white/20 dark:border-white/10">
      <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between" aria-label="Navigation principale">
        <a href="/" class="flex items-center gap-2" aria-label="customApps - Accueil">
          <div class="w-8 h-8 bg-gradient-to-br from-blue-600 to-violet-600 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
            </svg>
          </div>
          <span class="text-xl font-bold text-gradient">customApps</span>
        </a>
        <div class="hidden md:flex items-center gap-8">
          <a href="/#apps" class="text-sm text-gray-600 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-colors font-medium">Applications</a>
          <a href="/blog" class="text-sm text-gray-600 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-colors font-medium">Blog</a>
          <a href="/contact" class="text-sm text-gray-600 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-colors font-medium">Contact</a>
        </div>
        <div class="flex items-center gap-2">
          <!-- Toggle dark/light mode -->
          <button id="theme-toggle" type="button"
            class="relative p-2 rounded-full text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:bg-gray-800 dark:hover:bg-gray-800 transition-colors"
            aria-label="Basculer le thème clair/sombre">
            <!-- Icône soleil (visible en light) -->
            <svg class="w-5 h-5 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
            </svg>
            <!-- Icône lune (visible en dark) -->
            <svg class="w-5 h-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
            </svg>
          </button>
          <a href="/contact" class="bg-gradient-to-r from-blue-600 to-violet-600 text-white px-5 py-2 rounded-full text-sm font-semibold hover:shadow-lg hover:shadow-blue-500/25 transition-all duration-300 hover:-translate-y-0.5">
            Demander une démo
          </a>
        </div>
      </nav>
    </header>

    <!-- Spacer for fixed header -->
    <div class="h-16"></div>

    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-gradient-to-b from-gray-900 to-gray-950 text-white mt-20">
      <div class="max-w-6xl mx-auto px-6 py-16">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
          <div class="md:col-span-2">
            <div class="flex items-center gap-2 mb-4">
              <div class="w-8 h-8 bg-gradient-to-br from-blue-500 to-violet-500 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
                </svg>
              </div>
              <span class="text-xl font-bold">customApps</span>
            </div>
            <p class="text-gray-400 dark:text-gray-500 text-sm leading-relaxed max-w-md">
              La suite d'applications mobiles qui digitalise vos opérations terrain :
              ventes, achats, expéditions et gestion documentaire. Synchronisation temps réel avec votre ERP WaveSoft.
            </p>
            <div class="flex gap-3 mt-6">
              <span class="inline-flex items-center gap-1.5 bg-white/10 text-gray-300 dark:text-gray-600 px-3 py-1.5 rounded-full text-xs font-medium">
                <svg class="w-3.5 h-3.5 text-green-400" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="6"/></svg>
                Mode hors-ligne
              </span>
              <span class="inline-flex items-center gap-1.5 bg-white/10 text-gray-300 dark:text-gray-600 px-3 py-1.5 rounded-full text-xs font-medium">
                <svg class="w-3.5 h-3.5 text-blue-400" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="6"/></svg>
                Compatible WaveSoft
              </span>
            </div>
          </div>
          <div>
            <h3 class="font-semibold text-white mb-4 text-sm uppercase tracking-wider">Applications</h3>
            <ul id="footer-apps-list" class="space-y-3 text-sm text-gray-400 dark:text-gray-500">
              <li><a href="/apps/custom-sales" class="hover:text-white transition-colors">customSales</a></li>
              <li><a href="/apps/custom-supply" class="hover:text-white transition-colors">customSupply</a></li>
              <li><a href="/apps/custom-shipping" class="hover:text-white transition-colors">customShipping</a></li>
              <li><a href="/apps/custom-file-sync" class="hover:text-white transition-colors">customFileSync</a></li>
            </ul>
          </div>
          <div>
            <h3 class="font-semibold text-white mb-4 text-sm uppercase tracking-wider">Ressources</h3>
            <ul class="space-y-3 text-sm text-gray-400 dark:text-gray-500">
              <li><a href="/blog" class="hover:text-white transition-colors">Blog</a></li>
              <li><a href="/rss.xml" class="hover:text-white transition-colors">Flux RSS</a></li>
              <li><a href="/contact" class="hover:text-white transition-colors">Demander une démo</a></li>
              <li class="flex items-center gap-2 pt-2 border-t border-white/10 mt-2">
                <svg class="w-4 h-4 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                contact@customapps.fr
              </li>
            </ul>
          </div>
        </div>
        <div class="border-t border-white/10 mt-12 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
          <p class="text-sm text-gray-500 dark:text-gray-400">
            &copy; {new Date().getFullYear()} customApps. Tous droits réservés.
          </p>
          <p class="text-xs text-gray-600 dark:text-gray-300">
            Fait avec passion en France
          </p>
        </div>
      </div>
    </footer>

    <!-- WhatsApp floating button -->
    <a href="https://wa.me/33648948094" target="_blank" rel="noopener noreferrer"
       aria-label="Nous contacter sur WhatsApp"
       title="Nous contacter sur WhatsApp"
       class="fixed bottom-6 right-6 z-50 group">
      <span class="absolute inset-0 rounded-full bg-green-500 opacity-60 animate-ping"></span>
      <span class="relative flex items-center justify-center w-14 h-14 rounded-full shadow-lg text-white transition-transform group-hover:scale-110"
            style="background-color: #25D366;">
        <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
      </span>
    </a>

    <!-- Theme toggle : bascule light/dark + persistance localStorage -->
    <script is:inline>
      (function() {
        const btn = document.getElementById('theme-toggle');
        if (!btn) return;
        btn.addEventListener('click', () => {
          const isDark = document.documentElement.classList.toggle('dark');
          try {
            localStorage.setItem('customapps-theme', isDark ? 'dark' : 'light');
          } catch (e) {}
        });
      })();
    </script>

    <!-- Scroll reveal observer : applique .is-visible dès qu'un élément .reveal / .reveal-scale entre dans le viewport -->
    <script is:inline>
      (() => {
        if (typeof IntersectionObserver === 'undefined') {
          document.querySelectorAll('.reveal, .reveal-scale').forEach(el => el.classList.add('is-visible'));
          return;
        }
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.12, rootMargin: '0px 0px -60px 0px' });
        document.querySelectorAll('.reveal, .reveal-scale').forEach(el => observer.observe(el));
      })();
    </script>

    <!-- Hydratation du footer : rebuild la liste des apps au runtime pour refléter les modifs admin -->
    <script define:vars={{ API_URL }}>
      (async () => {
        const list = document.getElementById('footer-apps-list');
        if (!list) return;
        try {
          const res = await fetch(`${API_URL}/api/apps`, { cache: 'no-store' });
          if (!res.ok) return;
          const apps = await res.json();
          if (!Array.isArray(apps) || apps.length === 0) return;
          const escapeHtml = (s) => String(s ?? '').replace(/[&<>"']/g, (m) => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[m]));
          list.innerHTML = apps.map((a) => `
            <li><a href="/apps/${encodeURIComponent(a.slug)}" class="hover:text-white transition-colors">${escapeHtml(a.name)}</a></li>
          `).join('');
        } catch {}
      })();
    </script>
  </body>
</html>

<style>
  @import "../styles/global.css";
</style>
