---
import Base from '../layouts/Base.astro';
---

<Base title="Fonctionnalites - SmartSales">
  <section class="max-w-6xl mx-auto px-6 py-16">
    <h1 class="text-4xl font-bold text-gray-900 mb-4 text-center">Fonctionnalites</h1>
    <p class="text-lg text-gray-500 text-center mb-16 max-w-2xl mx-auto">
      SmartSales equipe vos commerciaux itinerants avec tous les outils necessaires pour vendre efficacement sur le terrain.
    </p>

    <div class="space-y-16">
      {[
        {
          title: "Catalogue produits intelligent",
          items: [
            "Consultation du catalogue complet avec photos et fiches produit",
            "Recherche instantanee par reference, designation ou famille",
            "Filtres avances par categorie et sous-categorie",
            "Affichage des articles les plus commandes (analyse 20/80)",
            "Gestion des articles favoris par commercial",
          ],
        },
        {
          title: "Prise de commandes",
          items: [
            "Creation de commandes en quelques taps depuis le catalogue",
            "Application automatique des tarifs clients et grilles tarifaires",
            "Gestion des remises (pourcentage ou montant)",
            "Historique des commandes par client",
            "Transformation de devis en commande",
          ],
        },
        {
          title: "Devis professionnels",
          items: [
            "Creation de devis avec conditions commerciales",
            "Generation de PDF professionnels avec logo et mentions legales",
            "Envoi par email directement depuis l'application",
            "Suivi des devis (en attente, accepte, refuse)",
            "Duree de validite configurable",
          ],
        },
        {
          title: "Gestion clients",
          items: [
            "Fiche client complete (coordonnees, contacts, conditions)",
            "Historique des factures, bons de livraison et commandes",
            "Filtrage par secteur commercial",
            "Encours et situation comptable",
            "Contacts multiples par client",
          ],
        },
        {
          title: "Mode hors-ligne & synchronisation",
          items: [
            "Fonctionnement complet sans connexion internet",
            "Base de donnees locale sur l'appareil (SQLite)",
            "Synchronisation automatique des que la connexion revient",
            "Synchronisation bidirectionnelle avec l'ERP WaveSoft",
            "Detection automatique du reseau (local ou distant)",
          ],
        },
        {
          title: "Integration ERP WaveSoft",
          items: [
            "Connexion native avec WaveSoft via le service de synchronisation",
            "Import automatique des clients, articles et tarifs",
            "Export des commandes et devis vers WaveSoft (format EDI)",
            "Synchronisation des factures et bons de livraison",
            "Aucune double saisie : les donnees circulent dans les deux sens",
          ],
        },
      ].map(({ title, items }) => (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
          <div>
            <h2 class="text-2xl font-bold text-gray-900 mb-2">{title}</h2>
          </div>
          <ul class="space-y-3">
            {items.map((item) => (
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-blue-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-gray-600">{item}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>
</Base>
