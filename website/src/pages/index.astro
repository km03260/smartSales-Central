---
import Base from '../layouts/Base.astro';
import PhoneMockup from '../components/PhoneMockup.astro';

const API_URL = import.meta.env.PUBLIC_API_URL || 'https://api.customapps.fr';

// ─── FAQ : contenu + schema JSON-LD ─────────────────────────────────────────
const FAQ_ITEMS = [
  {
    q: "Comment s'installent les applications customApps sur les smartphones Android ?",
    a: "L'installation se fait en scannant un QR code ou en téléchargeant directement l'APK depuis votre page produit. Pas de passage par le Play Store — vos équipes installent l'app en moins d'une minute et saisissent leur clé de licence pour activer l'appareil.",
  },
  {
    q: "Faut-il obligatoirement WaveSoft pour utiliser customApps ?",
    a: "Aujourd'hui oui — l'ensemble de la suite est conçu autour d'un service de synchronisation (SyncService) qui se connecte à votre base WaveSoft. Si vous utilisez un autre ERP, contactez-nous : nous étudions au cas par cas la faisabilité d'un connecteur dédié.",
  },
  {
    q: "Que se passe-t-il quand mes équipes terrain n'ont pas de réseau ?",
    a: "Toutes les apps fonctionnent entièrement hors-ligne. Les données (clients, articles, commandes, documents) sont stockées localement sur l'appareil. Dès que la connexion revient, la synchronisation rattrape automatiquement les saisies faites sans réseau. Zéro perte de données.",
  },
  {
    q: "Combien d'utilisateurs et d'appareils couvre une licence ?",
    a: "Le nombre d'appareils maximum est défini par votre plan (Starter, Pro, Enterprise). Vous pouvez gérer les activations depuis votre espace admin : voir les appareils connectés, désactiver un appareil perdu, ré-attribuer une licence à un nouveau commercial.",
  },
  {
    q: "Les données métier transitent-elles par vos serveurs ?",
    a: "Non. Le SyncService est installé sur vos propres serveurs (on-premise ou votre cloud privé) et communique directement avec vos apps mobiles via HTTPS chiffré. Nous ne stockons jamais vos données clients, articles ou commandes — uniquement les métadonnées de licence pour vérifier vos activations.",
  },
  {
    q: "Quel est le délai de mise en place d'une solution customApps ?",
    a: "De 2 à 10 jours selon la complexité. Phase 1 : installation du SyncService sur votre infrastructure (½ journée). Phase 2 : paramétrage des règles métier (secteurs, tarifs, conditions) et tests sur un poste pilote (2-5 jours). Phase 3 : déploiement sur le parc d'appareils (½ journée par vague de 10 commerciaux).",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": FAQ_ITEMS.map(({ q, a }) => ({
    "@type": "Question",
    "name": q,
    "acceptedAnswer": { "@type": "Answer", "text": a },
  })),
};

const FALLBACK_APPS = [
  { code: 'SS', slug: 'custom-sales',     name: 'customSales',     tagline: "La force de vente mobile qui ne s'arrête jamais",            description: "Commandes, devis et catalogue depuis le mobile — même sans réseau.",            color: 'blue',    iconSvgPath: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6' },
  { code: 'SP', slug: 'custom-supply',    name: 'customSupply',    tagline: 'Achetez mieux, suivez chaque commande',                       description: "Demandes d'achat, commandes fournisseurs et réceptions scannées.",                color: 'emerald', iconSvgPath: 'M20 7l-8-4-8 4m16 0v10l-8 4m0 0l-8-4V7m8 4v10' },
  { code: 'SH', slug: 'custom-shipping',  name: 'customShipping',  tagline: 'Chaque colis, chaque livraison, parfaitement orchestrés',     description: 'Picking guidé, étiquettes transporteurs et émargement client.',                   color: 'orange',  iconSvgPath: 'M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4' },
  { code: 'FS', slug: 'custom-file-sync', name: 'customFileSync',  tagline: 'Vos documents techniques, toujours à portée de main',          description: "Synchronisation sécurisée des documents entre ERP et mobile.",                    color: 'violet',  iconSvgPath: 'M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12' },
];

let apps = FALLBACK_APPS;
try {
  const res = await fetch(`${API_URL}/api/apps`);
  if (res.ok) {
    const data = await res.json();
    if (Array.isArray(data) && data.length > 0) apps = data;
  }
} catch {
  // fallback
}

const COLOR_CLASSES = {
  blue:    { from: 'from-blue-500',    to: 'to-blue-600',    fromDark: 'from-blue-600',    toDark: 'to-violet-600',   text: 'text-blue-600',    bg: 'bg-blue-50',    mesh: 'from-blue-100/40' },
  violet:  { from: 'from-violet-500',  to: 'to-violet-600',  fromDark: 'from-violet-600',  toDark: 'to-pink-600',     text: 'text-violet-600',  bg: 'bg-violet-50',  mesh: 'from-violet-100/40' },
  emerald: { from: 'from-emerald-500', to: 'to-emerald-600', fromDark: 'from-emerald-600', toDark: 'to-teal-600',     text: 'text-emerald-600', bg: 'bg-emerald-50', mesh: 'from-emerald-100/40' },
  orange:  { from: 'from-orange-500',  to: 'to-orange-600',  fromDark: 'from-orange-600',  toDark: 'to-pink-600',     text: 'text-orange-600',  bg: 'bg-orange-50',  mesh: 'from-orange-100/40' },
};

// Map slug → phone mockup variant
const MOCKUP_VARIANT = {
  'custom-sales':     'sales',
  'custom-supply':    'supply',
  'custom-shipping':  'shipping',
  'custom-file-sync': 'fileSync',
};
---

<Base
  title="customApps — Une suite d'apps pour digitaliser vos opérations terrain"
  description="customApps est une suite d'applications mobiles compatibles ERP WaveSoft : ventes, achats, expéditions, synchronisation de fichiers. Mode hors-ligne, sync temps réel."
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-noise">
    <!-- Aurora gradient background -->
    <div class="absolute inset-0 -z-10 bg-mesh">
      <div class="absolute top-10 -left-40 w-[500px] h-[500px] bg-gradient-to-br from-blue-200/40 via-violet-100/40 to-transparent rounded-full blur-3xl animate-aurora"></div>
      <div class="absolute top-40 right-0 w-[600px] h-[500px] bg-gradient-to-bl from-pink-100/40 via-violet-100/30 to-transparent rounded-full blur-3xl animate-aurora" style="animation-delay: -6s"></div>
    </div>

    <div class="max-w-7xl mx-auto px-6 pt-16 md:pt-24 pb-12 grid md:grid-cols-2 gap-12 items-center">
      <!-- Texte -->
      <div>
        <div class="animate-fade-in-up inline-flex items-center gap-2 glass-strong text-blue-700 px-4 py-1.5 rounded-full text-sm font-medium mb-8">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-60"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-blue-500"></span>
          </span>
          Compatible WaveSoft ERP · Mode hors-ligne
        </div>

        <h1 class="animate-fade-in-up delay-100 text-5xl md:text-7xl font-extrabold text-gray-900 dark:text-gray-100 leading-[1.05] mb-6 tracking-tight">
          Une suite d'apps
          <span class="block">pour <span class="font-display-italic text-gradient">digitaliser</span></span>
          <span class="block">le terrain.</span>
        </h1>

        <p class="animate-fade-in-up delay-200 text-lg md:text-xl text-gray-500 dark:text-gray-300 max-w-xl mb-10 leading-relaxed">
          Ventes, achats, expéditions, documents : <strong class="text-gray-900 dark:text-gray-100 font-semibold"><span id="apps-count-inline">{apps.length}</span> applications mobiles</strong> qui fonctionnent hors-ligne et se synchronisent en temps réel avec votre ERP.
        </p>

        <div class="animate-fade-in-up delay-300 flex flex-col sm:flex-row gap-3">
          <a href="#apps" class="group inline-flex items-center justify-center gap-2 bg-gray-900 text-white px-6 py-3.5 rounded-full font-semibold hover:bg-gray-800 transition-all duration-300 hover:-translate-y-0.5 shadow-xl shadow-gray-900/20">
            Découvrir la suite
            <svg class="w-4 h-4 transition-transform group-hover:translate-y-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
          </a>
          <a href="/contact" class="group inline-flex items-center justify-center gap-2 glass-strong text-gray-700 dark:text-gray-200 px-6 py-3.5 rounded-full font-semibold hover:bg-white dark:bg-gray-900 transition-all duration-300 hover:-translate-y-0.5">
            Demander une démo
            <span class="inline-block transition-transform group-hover:translate-x-0.5">&rarr;</span>
          </a>
        </div>

        <!-- Trust strip -->
        <div class="animate-fade-in-up delay-500 flex items-center gap-6 mt-12 text-sm text-gray-500 dark:text-gray-300">
          <div class="flex items-center gap-2">
            <div class="flex -space-x-2">
              {[0,1,2,3].map((i) => (
                <div class={`w-7 h-7 rounded-full border-2 border-white bg-gradient-to-br ${['from-blue-400 to-blue-600','from-violet-400 to-violet-600','from-emerald-400 to-emerald-600','from-orange-400 to-orange-600'][i]}`}></div>
              ))}
            </div>
            <span>Déjà adopté par des équipes terrain</span>
          </div>
        </div>
      </div>

      <!-- Phone mockup -->
      <div class="relative flex justify-center items-center animate-scale-in delay-200">
        <div class="absolute inset-0 bg-gradient-to-br from-blue-200/30 via-violet-200/30 to-pink-200/30 rounded-full blur-3xl"></div>
        <div class="relative">
          <PhoneMockup variant="sales" />
        </div>
      </div>
    </div>
  </section>

  <!-- Marquee / Trust -->
  <section class="border-y border-gray-100 dark:border-gray-700 bg-white dark:bg-gray-900">
    <div class="max-w-6xl mx-auto px-6 py-12">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        {[
          { id: 'apps-count-stat', value: `${apps.length}`,   label: 'Applications' },
          { id: null,              value: '99.9%',            label: 'Disponibilité' },
          { id: null,              value: '< 2s',             label: 'Sync. moyenne' },
          { id: null,              value: '100%',             label: 'Hors-ligne' },
        ].map(({ id, value, label }) => (
          <div class="reveal">
            <div id={id} class="text-4xl md:text-5xl font-extrabold text-gradient mb-1 tracking-tight">{value}</div>
            <div class="text-xs text-gray-500 dark:text-gray-300 font-medium uppercase tracking-wider">{label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Catalogue des apps -->
  <section id="apps" class="relative py-28 overflow-hidden">
    <div class="absolute inset-0 -z-10 bg-mesh-soft"></div>

    <div class="max-w-7xl mx-auto px-6">
      <div class="reveal text-center mb-16">
        <span class="inline-block text-sm font-semibold text-blue-600 mb-3 uppercase tracking-wider">La suite customApps</span>
        <h2 class="text-4xl md:text-5xl font-extrabold text-gray-900 dark:text-gray-100 mb-4 tracking-tight">
          Une application par métier,<br/>
          <span class="font-display-italic text-gray-500 dark:text-gray-300">un ERP unique.</span>
        </h2>
        <p class="text-lg text-gray-500 dark:text-gray-300 max-w-2xl mx-auto">
          Chaque app partage la même base technique et la même compatibilité WaveSoft. Déployez celles qui correspondent à vos équipes.
        </p>
      </div>

      <div id="apps-catalog" class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {apps.map((app, i) => {
          const c = COLOR_CLASSES[app.color] || COLOR_CLASSES.blue;
          const variant = MOCKUP_VARIANT[app.slug] || 'sales';
          return (
            <a
              href={`/apps/${app.slug}`}
              data-slug={app.slug}
              class={`reveal card-premium group relative overflow-hidden glass-strong rounded-3xl p-8 pt-10 flex flex-col md:flex-row md:items-center gap-6 min-h-[320px]`}
              style={`transition-delay: ${i * 80}ms`}
            >
              <div class={`absolute -top-20 -right-20 w-80 h-80 bg-gradient-to-br ${c.mesh} to-transparent rounded-full blur-3xl opacity-60 group-hover:opacity-100 transition-opacity`}></div>

              <div class="relative z-10 flex-1 min-w-0">
                <div class={`inline-flex w-12 h-12 bg-gradient-to-br ${c.from} ${c.to} rounded-xl items-center justify-center mb-4 shadow-lg`}>
                  <svg class="w-6 h-6 text-white js-app-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={app.iconSvgPath} />
                  </svg>
                </div>

                <div class="flex items-center gap-2 mb-2">
                  <h3 class="js-app-name text-2xl font-extrabold text-gray-900 dark:text-gray-100 tracking-tight">{app.name}</h3>
                  <span class={`js-app-code text-[10px] font-mono px-1.5 py-0.5 ${c.bg} ${c.text} rounded`}>{app.code}</span>
                </div>

                <p class={`js-app-tagline text-sm font-semibold ${c.text} mb-2 ${app.tagline ? '' : 'hidden'}`}>{app.tagline}</p>
                <p class="js-app-description text-sm text-gray-500 dark:text-gray-300 leading-relaxed mb-4 line-clamp-3">{app.description}</p>

                <span class={`inline-flex items-center gap-1 text-sm font-semibold ${c.text} group-hover:gap-2 transition-all`}>
                  En savoir plus
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </span>
              </div>

              {/* Mockup compact de l'app sur la droite */}
              <div class="relative z-10 hidden sm:block flex-shrink-0 self-center">
                <div class="phone-compact-wrap group-hover:-translate-y-1 transition-transform duration-500">
                  <div class="phone-compact-scale">
                    <PhoneMockup variant={variant} />
                  </div>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Comment ça marche -->
  <section class="relative py-28 bg-gradient-to-br from-gray-50 via-white to-blue-50/30 dark:from-gray-950 dark:via-gray-900 dark:to-blue-950/40 overflow-hidden">
    <div class="max-w-6xl mx-auto px-6">
      <div class="reveal text-center mb-16">
        <span class="inline-block text-sm font-semibold text-blue-600 mb-3 uppercase tracking-wider">Simple</span>
        <h2 class="text-4xl md:text-5xl font-extrabold text-gray-900 dark:text-gray-100 mb-4 tracking-tight">
          Trois étapes<br/>
          <span class="font-display-italic text-gray-500 dark:text-gray-300">pour démarrer.</span>
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {/* Étape 1 — Choisir les apps */}
        <div class="reveal relative text-center" style="transition-delay: 0ms">
          <div class="relative mx-auto w-full max-w-[240px] aspect-square mb-6">
            <svg viewBox="0 0 240 240" class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <linearGradient id="step1-bg" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" stop-color="#dbeafe"/>
                  <stop offset="100%" stop-color="#ede9fe"/>
                </linearGradient>
              </defs>
              <circle cx="120" cy="120" r="100" fill="url(#step1-bg)"/>
              {/* 4 cartes d'apps qui flottent */}
              <rect x="55" y="70" width="60" height="60" rx="14" fill="#3b82f6" transform="rotate(-8 85 100)"/>
              <rect x="120" y="60" width="60" height="60" rx="14" fill="#10b981" transform="rotate(5 150 90)"/>
              <rect x="50" y="135" width="60" height="60" rx="14" fill="#f97316" transform="rotate(4 80 165)"/>
              <rect x="125" y="140" width="60" height="60" rx="14" fill="#8b5cf6" transform="rotate(-6 155 170)"/>
              {/* Mains curseur / sélection */}
              <circle cx="150" cy="90" r="10" fill="#fff" opacity="0.9"/>
              <path d="M145,88 L155,92 L152,98 L150,95 L148,98 Z" fill="#1e3a8a"/>
              {/* Checkmark sur app 2 */}
              <circle cx="170" cy="75" r="12" fill="#10b981" stroke="#fff" stroke-width="3"/>
              <path d="M164,75 L168,79 L176,71" stroke="#fff" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <div class="absolute -top-2 -right-2 inline-flex items-center justify-center w-12 h-12 bg-gradient-to-br from-blue-600 to-violet-600 rounded-2xl text-white text-xl font-extrabold shadow-xl shadow-blue-500/30">1</div>
          </div>
          <h3 class="font-bold text-gray-900 dark:text-gray-100 mb-2 text-xl">Choisissez vos apps</h3>
          <p class="text-sm text-gray-500 dark:text-gray-300 leading-relaxed max-w-xs mx-auto">Selon vos besoins terrain : ventes, achats, expéditions ou gestion documentaire.</p>
        </div>

        {/* Étape 2 — Connecter WaveSoft */}
        <div class="reveal relative text-center" style="transition-delay: 120ms">
          <div class="relative mx-auto w-full max-w-[240px] aspect-square mb-6">
            <svg viewBox="0 0 240 240" class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <linearGradient id="step2-bg" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" stop-color="#ecfdf5"/>
                  <stop offset="100%" stop-color="#dbeafe"/>
                </linearGradient>
                <linearGradient id="step2-line" x1="0%" y1="50%" x2="100%" y2="50%">
                  <stop offset="0%" stop-color="#3b82f6"/>
                  <stop offset="100%" stop-color="#10b981"/>
                </linearGradient>
              </defs>
              <circle cx="120" cy="120" r="100" fill="url(#step2-bg)"/>
              {/* Serveur ERP à gauche */}
              <g transform="translate(40, 85)">
                <rect x="0" y="0" width="55" height="70" rx="6" fill="#1e293b"/>
                <rect x="6" y="8" width="43" height="6" rx="2" fill="#64748b"/>
                <rect x="6" y="20" width="43" height="6" rx="2" fill="#10b981"/>
                <rect x="6" y="32" width="43" height="6" rx="2" fill="#64748b"/>
                <rect x="6" y="44" width="43" height="6" rx="2" fill="#10b981"/>
                <circle cx="15" cy="60" r="2" fill="#10b981"/>
                <circle cx="22" cy="60" r="2" fill="#3b82f6"/>
              </g>
              <text x="67" y="170" text-anchor="middle" font-family="Inter" font-size="11" font-weight="600" fill="#475569">WaveSoft</text>
              {/* Téléphone à droite */}
              <g transform="translate(145, 75)">
                <rect x="0" y="0" width="55" height="90" rx="10" fill="#1e293b"/>
                <rect x="4" y="4" width="47" height="82" rx="6" fill="#f8fafc"/>
                <rect x="10" y="12" width="35" height="4" rx="2" fill="#3b82f6"/>
                <rect x="10" y="22" width="35" height="25" rx="3" fill="#dbeafe"/>
                <rect x="10" y="52" width="35" height="6" rx="2" fill="#cbd5e1"/>
                <rect x="10" y="62" width="25" height="6" rx="2" fill="#cbd5e1"/>
                <rect x="10" y="72" width="30" height="6" rx="2" fill="#cbd5e1"/>
              </g>
              <text x="172" y="185" text-anchor="middle" font-family="Inter" font-size="11" font-weight="600" fill="#475569">Mobile</text>
              {/* Ligne de connexion animée */}
              <path d="M 95,120 Q 120,100 145,120" stroke="url(#step2-line)" stroke-width="3" fill="none" stroke-linecap="round" stroke-dasharray="5 3"/>
              {/* SyncService badge au milieu */}
              <g transform="translate(120, 120)">
                <circle r="16" fill="#fff" stroke="#10b981" stroke-width="2"/>
                <path d="M-6,-2 L-2,2 L6,-6" stroke="#10b981" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
              </g>
            </svg>
            <div class="absolute -top-2 -right-2 inline-flex items-center justify-center w-12 h-12 bg-gradient-to-br from-blue-600 to-violet-600 rounded-2xl text-white text-xl font-extrabold shadow-xl shadow-blue-500/30">2</div>
          </div>
          <h3 class="font-bold text-gray-900 dark:text-gray-100 mb-2 text-xl">Connectez WaveSoft</h3>
          <p class="text-sm text-gray-500 dark:text-gray-300 leading-relaxed max-w-xs mx-auto">Notre SyncService sécurisé ponte vos apps mobiles avec votre ERP existant.</p>
        </div>

        {/* Étape 3 — Déployer sur le terrain */}
        <div class="reveal relative text-center" style="transition-delay: 240ms">
          <div class="relative mx-auto w-full max-w-[240px] aspect-square mb-6">
            <svg viewBox="0 0 240 240" class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <linearGradient id="step3-bg" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" stop-color="#fed7aa"/>
                  <stop offset="100%" stop-color="#fbcfe8"/>
                </linearGradient>
              </defs>
              <circle cx="120" cy="120" r="100" fill="url(#step3-bg)"/>
              {/* QR code simulé */}
              <g transform="translate(135, 65)">
                <rect width="70" height="70" rx="10" fill="#fff" stroke="#0f172a" stroke-width="2"/>
                <rect x="10" y="10" width="15" height="15" rx="2" fill="#0f172a"/>
                <rect x="45" y="10" width="15" height="15" rx="2" fill="#0f172a"/>
                <rect x="10" y="45" width="15" height="15" rx="2" fill="#0f172a"/>
                <rect x="30" y="30" width="5" height="5" fill="#0f172a"/>
                <rect x="40" y="35" width="5" height="5" fill="#0f172a"/>
                <rect x="50" y="45" width="5" height="5" fill="#0f172a"/>
                <rect x="35" y="50" width="5" height="5" fill="#0f172a"/>
                <rect x="45" y="55" width="5" height="5" fill="#0f172a"/>
              </g>
              {/* Silhouette + téléphone en main */}
              <g transform="translate(40, 80)">
                <circle cx="25" cy="20" r="15" fill="#fff" stroke="#f97316" stroke-width="3"/>
                <path d="M 10,50 Q 10,35 25,35 Q 40,35 40,50 L 40,110 L 10,110 Z" fill="#fff" stroke="#f97316" stroke-width="3"/>
                {/* téléphone dans la main */}
                <rect x="38" y="55" width="22" height="35" rx="4" fill="#1e293b" stroke="#f97316" stroke-width="2"/>
                <rect x="40" y="57" width="18" height="31" rx="2" fill="#f8fafc"/>
                <rect x="43" y="61" width="12" height="2" rx="1" fill="#3b82f6"/>
                <rect x="43" y="66" width="12" height="6" rx="1" fill="#dbeafe"/>
              </g>
              {/* Rayons depuis le QR code */}
              <g transform="translate(100, 100)" opacity="0.6" stroke="#f97316" stroke-width="2" stroke-linecap="round" fill="none">
                <path d="M 0,0 L -10,-10"/>
                <path d="M 0,10 L -15,5"/>
                <path d="M -5,20 L -15,25"/>
              </g>
            </svg>
            <div class="absolute -top-2 -right-2 inline-flex items-center justify-center w-12 h-12 bg-gradient-to-br from-blue-600 to-violet-600 rounded-2xl text-white text-xl font-extrabold shadow-xl shadow-blue-500/30">3</div>
          </div>
          <h3 class="font-bold text-gray-900 dark:text-gray-100 mb-2 text-xl">Déployez sur le terrain</h3>
          <p class="text-sm text-gray-500 dark:text-gray-300 leading-relaxed max-w-xs mx-auto">Vos équipes installent via QR code et travaillent immédiatement, même sans réseau.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Hydratation runtime du catalogue (reflète les modifs admin sans rebuild) -->
  <script define:vars={{ API_URL }}>
    (async () => {
      try {
        const res = await fetch(`${API_URL}/api/apps`, { cache: 'no-store' });
        if (!res.ok) return;
        const apps = await res.json();
        if (!Array.isArray(apps)) return;

        apps.forEach((app) => {
          const card = document.querySelector(`#apps-catalog a[data-slug="${app.slug}"]`);
          if (!card) return;
          const name = card.querySelector('.js-app-name');
          const code = card.querySelector('.js-app-code');
          const tagline = card.querySelector('.js-app-tagline');
          const description = card.querySelector('.js-app-description');
          const icon = card.querySelector('.js-app-icon path');
          if (name && app.name) name.textContent = app.name;
          if (code && app.code) code.textContent = app.code;
          if (tagline) {
            if (app.tagline) { tagline.textContent = app.tagline; tagline.classList.remove('hidden'); }
            else             { tagline.classList.add('hidden'); }
          }
          if (description && app.description) description.textContent = app.description;
          if (icon && app.iconSvgPath) icon.setAttribute('d', app.iconSvgPath);
        });

        // Mettre à jour les compteurs d'apps (hero + stats)
        const count = apps.length;
        const inline = document.getElementById('apps-count-inline');
        const stat   = document.getElementById('apps-count-stat');
        if (inline) inline.textContent = count;
        if (stat)   stat.textContent   = count;
      } catch {}
    })();
  </script>

