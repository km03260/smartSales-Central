---
import Base from '../layouts/Base.astro';
---

<Base title="Contact - SmartSales" description="Contactez l'équipe SmartSales pour une démonstration gratuite. Réponse sous 24h. Demandez un devis personnalisé pour votre équipe commerciale.">
  <!-- Header -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 -z-10">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[400px] bg-gradient-to-br from-blue-100 via-violet-50 to-transparent rounded-full blur-3xl opacity-50"></div>
    </div>
    <div class="max-w-6xl mx-auto px-6 py-20 text-center">
      <span class="inline-block text-sm font-semibold text-blue-600 mb-3 uppercase tracking-wider">Contact</span>
      <h1 class="text-4xl md:text-5xl font-extrabold text-gray-900 mb-4 tracking-tight">Contactez-nous</h1>
      <p class="text-lg text-gray-500 max-w-2xl mx-auto leading-relaxed">
        Vous souhaitez une démonstration ou avez des questions ? Nous vous répondons sous 24h.
      </p>
    </div>
  </section>

  <!-- Form + Info -->
  <section class="max-w-6xl mx-auto px-6 pb-24">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

      <!-- Contact info sidebar -->
      <div class="space-y-6">
        <div class="card-hover bg-gradient-to-br from-blue-600 via-blue-700 to-violet-700 rounded-2xl p-8 text-white shadow-xl shadow-blue-500/15">
          <h3 class="font-bold text-lg mb-6">Parlons de votre projet</h3>
          <div class="space-y-5">
            <div class="flex items-start gap-3">
              <div class="w-10 h-10 bg-white/15 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <p class="text-sm text-blue-200 mb-0.5">Email</p>
                <p class="font-medium">contact@smartsales.fr</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-10 h-10 bg-white/15 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <p class="text-sm text-blue-200 mb-0.5">Réponse</p>
                <p class="font-medium">Sous 24 heures</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-10 h-10 bg-white/15 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
              </div>
              <div>
                <p class="text-sm text-blue-200 mb-0.5">Démo</p>
                <p class="font-medium">Gratuite et sans engagement</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Quick benefits -->
        <div class="bg-gray-50 rounded-2xl p-6 border border-gray-100">
          <h4 class="font-bold text-gray-900 mb-4 text-sm">Ce que vous obtenez :</h4>
          <ul class="space-y-3">
            {[
              "Démonstration personnalisée de 30 min",
              "Étude de faisabilité gratuite",
              "Devis sur mesure sous 48h",
              "Accompagnement à la mise en place",
            ].map((item) => (
              <li class="flex items-start gap-2 text-sm text-gray-600">
                <div class="w-5 h-5 bg-green-100 rounded-full flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-3 h-3 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Contact form -->
      <div class="lg:col-span-2">
        <form id="contact-form" class="bg-white rounded-2xl border border-gray-100 shadow-sm p-8 space-y-6">
          <div id="form-message" class="hidden px-4 py-3 rounded-xl text-sm font-medium"></div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block text-sm font-semibold text-gray-700 mb-2">Nom *</label>
              <input type="text" id="name" name="name" required placeholder="Jean Dupont"
                class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent focus:bg-white transition-all" />
            </div>
            <div>
              <label for="email" class="block text-sm font-semibold text-gray-700 mb-2">Email *</label>
              <input type="email" id="email" name="email" required placeholder="jean@entreprise.fr"
                class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent focus:bg-white transition-all" />
            </div>
            <div>
              <label for="company" class="block text-sm font-semibold text-gray-700 mb-2">Entreprise</label>
              <input type="text" id="company" name="company" placeholder="Mon Entreprise SAS"
                class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent focus:bg-white transition-all" />
            </div>
            <div>
              <label for="phone" class="block text-sm font-semibold text-gray-700 mb-2">Téléphone</label>
              <input type="tel" id="phone" name="phone" placeholder="06 12 34 56 78"
                class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent focus:bg-white transition-all" />
            </div>
          </div>

          <div>
            <label for="type" class="block text-sm font-semibold text-gray-700 mb-2">Type de demande</label>
            <select id="type" name="type"
              class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent focus:bg-white transition-all">
              <option value="demo">Demande de démonstration</option>
              <option value="info">Demande d'information</option>
            </select>
          </div>

          <div>
            <label for="message" class="block text-sm font-semibold text-gray-700 mb-2">Message *</label>
            <textarea id="message" name="message" rows="5" required placeholder="Décrivez votre besoin, le nombre de commerciaux, votre ERP actuel..."
              class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent focus:bg-white transition-all resize-none"></textarea>
          </div>

          <button type="submit" id="submit-btn"
            class="w-full bg-gradient-to-r from-blue-600 to-violet-600 text-white py-3.5 px-4 rounded-xl font-semibold hover:shadow-lg hover:shadow-blue-500/25 transition-all duration-300 hover:-translate-y-0.5 cursor-pointer">
            Envoyer ma demande
          </button>

          <p class="text-xs text-gray-400 text-center">
            En soumettant ce formulaire, vous acceptez d'être contacté par notre équipe commerciale.
          </p>
        </form>
      </div>
    </div>
  </section>
</Base>

<script>
  const form = document.getElementById('contact-form');
  const msg = document.getElementById('form-message');
  const btn = document.getElementById('submit-btn');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled = true;
    btn.textContent = 'Envoi en cours...';
    msg.className = 'hidden';

    const data = {
      name: form.name.value,
      email: form.email.value,
      company: form.company.value,
      phone: form.phone.value,
      type: form.type.value,
      message: form.message.value,
    };

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        msg.textContent = 'Merci ! Votre demande a bien été envoyée. Nous vous recontactons sous 24h.';
        msg.className = 'bg-green-50 text-green-700 px-4 py-3 rounded-xl text-sm font-medium border border-green-100';
        form.reset();
      } else {
        throw new Error('Erreur serveur');
      }
    } catch {
      msg.textContent = 'Une erreur est survenue. Veuillez réessayer ou nous contacter par email.';
      msg.className = 'bg-red-50 text-red-700 px-4 py-3 rounded-xl text-sm font-medium border border-red-100';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Envoyer ma demande';
    }
  });
</script>
