---
import Base from '../../layouts/Base.astro';
import PhoneMockup from '../../components/PhoneMockup.astro';

const API_URL = import.meta.env.PUBLIC_API_URL || 'https://api.customapps.fr';

const FALLBACK_APPS = [
  { code: 'SS', slug: 'custom-sales',     name: 'customSales',    color: 'blue' },
  { code: 'SP', slug: 'custom-supply',    name: 'customSupply',   color: 'emerald' },
  { code: 'SH', slug: 'custom-shipping',  name: 'customShipping', color: 'orange' },
  { code: 'FS', slug: 'custom-file-sync', name: 'customFileSync', color: 'violet' },
];

const MOCKUP_VARIANT = {
  'custom-sales':     'sales',
  'custom-supply':    'supply',
  'custom-shipping':  'shipping',
  'custom-file-sync': 'fileSync',
};

export async function getStaticPaths() {
  const API_URL = import.meta.env.PUBLIC_API_URL || 'https://api.customapps.fr';
  try {
    const res = await fetch(`${API_URL}/api/apps`);
    if (res.ok) {
      const apps = await res.json();
      if (Array.isArray(apps) && apps.length > 0) {
        return apps.map((app) => ({ params: { slug: app.slug }, props: { app } }));
      }
    }
  } catch {}
  return [
    { params: { slug: 'custom-sales' },     props: { app: null } },
    { params: { slug: 'custom-supply' },    props: { app: null } },
    { params: { slug: 'custom-shipping' },  props: { app: null } },
    { params: { slug: 'custom-file-sync' }, props: { app: null } },
  ];
}

const { slug } = Astro.params;
let { app } = Astro.props;

if (!app || !app.features || !app.pricingPlans) {
  try {
    const res = await fetch(`${API_URL}/api/apps/${slug}`);
    if (res.ok) app = await res.json();
  } catch {}
}

if (!app) {
  const fallback = FALLBACK_APPS.find(a => a.slug === slug);
  app = {
    code: fallback?.code || '',
    slug,
    name: fallback?.name || slug,
    tagline: '',
    description: '',
    longDescription: '',
    color: fallback?.color || 'blue',
    iconSvgPath: '',
    apkUrl: null,
    qrcodeUrl: null,
    apkVersion: null,
    apkReleaseNotes: null,
    features: [],
    pricingPlans: [],
  };
}

const mockupVariant = MOCKUP_VARIANT[app.slug] || 'sales';

const COLOR_CLASSES = {
  blue:    { from: 'from-blue-500',    to: 'to-blue-600',    fromDark: 'from-blue-600',    toDark: 'to-violet-600',   text: 'text-blue-600',    bg: 'bg-blue-50',    bgSoft: 'from-blue-200/40',  ring: 'ring-blue-200',    border: 'border-blue-200',    shadow: 'shadow-blue-500/25',    accent: 'bg-blue-500',    mesh: 'from-blue-100/40' },
  violet:  { from: 'from-violet-500',  to: 'to-violet-600',  fromDark: 'from-violet-600',  toDark: 'to-pink-600',     text: 'text-violet-600',  bg: 'bg-violet-50',  bgSoft: 'from-violet-200/40', ring: 'ring-violet-200',  border: 'border-violet-200',  shadow: 'shadow-violet-500/25',  accent: 'bg-violet-500',  mesh: 'from-violet-100/40' },
  emerald: { from: 'from-emerald-500', to: 'to-emerald-600', fromDark: 'from-emerald-600', toDark: 'to-teal-600',     text: 'text-emerald-600', bg: 'bg-emerald-50', bgSoft: 'from-emerald-200/40', ring: 'ring-emerald-200', border: 'border-emerald-200', shadow: 'shadow-emerald-500/25', accent: 'bg-emerald-500', mesh: 'from-emerald-100/40' },
  orange:  { from: 'from-orange-500',  to: 'to-orange-600',  fromDark: 'from-orange-600',  toDark: 'to-pink-600',     text: 'text-orange-600',  bg: 'bg-orange-50',  bgSoft: 'from-orange-200/40',  ring: 'ring-orange-200',  border: 'border-orange-200',  shadow: 'shadow-orange-500/25',  accent: 'bg-orange-500',  mesh: 'from-orange-100/40' },
};
const c = COLOR_CLASSES[app.color] || COLOR_CLASSES.blue;

// Autres apps pour cross-linking "Découvrez aussi"
let otherApps = [];
try {
  const resAll = await fetch(`${API_URL}/api/apps`);
  if (resAll.ok) {
    const allApps = await resAll.json();
    if (Array.isArray(allApps)) {
      otherApps = allApps.filter((a) => a.slug !== app.slug).slice(0, 3);
    }
  }
} catch {}

const title = `${app.name} — ${app.tagline || app.description || 'customApps'} | customApps`;
const description = app.description || app.tagline || '';
const canonicalUrl = new URL(`/apps/${app.slug}/`, Astro.site).href;

// JSON-LD SoftwareApplication + BreadcrumbList
const plans = Array.isArray(app.pricingPlans) ? app.pricingPlans : [];
const prices = plans.map(p => parseFloat(String(p.price).replace(/[^0-9.]/g, ''))).filter(Number.isFinite);
const lowPrice = prices.length ? Math.min(...prices) : null;
const highPrice = prices.length ? Math.max(...prices) : null;

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": app.name,
  "description": app.longDescription || app.description || app.tagline || '',
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Android 8+",
  "url": canonicalUrl,
  ...(lowPrice != null && highPrice != null ? {
    "offers": {
      "@type": "AggregateOffer",
      "priceCurrency": "EUR",
      "lowPrice": String(lowPrice),
      "highPrice": String(highPrice),
      "offerCount": String(plans.length),
    }
  } : {}),
  "publisher": {
    "@type": "Organization",
    "name": "customApps",
    "url": "https://customapps.fr",
  },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://customapps.fr/" },
    { "@type": "ListItem", "position": 2, "name": "Applications", "item": "https://customapps.fr/#apps" },
    { "@type": "ListItem", "position": 3, "name": app.name, "item": canonicalUrl },
  ],
};
---


<Base title={title} description={description}>
  <!-- JSON-LD : SoftwareApplication + BreadcrumbList -->
  <script type="application/ld+json" set:html={JSON.stringify(softwareSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- Hero -->
  <section class="relative overflow-hidden bg-noise">
    <div class="absolute inset-0 -z-10">
      <div class={`absolute top-0 -left-40 w-[600px] h-[600px] bg-gradient-to-br ${c.bgSoft} to-transparent rounded-full blur-3xl animate-aurora`}></div>
      <div class={`absolute top-20 right-0 w-[500px] h-[500px] bg-gradient-to-bl ${c.bgSoft} to-transparent rounded-full blur-3xl animate-aurora`} style="animation-delay: -5s"></div>
    </div>

    <div class="max-w-7xl mx-auto px-6 pt-12 md:pt-20 pb-16 grid md:grid-cols-2 gap-12 items-center">
      <div>
        <!-- Fil d'ariane SEO + accessibilité -->
        <nav aria-label="Fil d'ariane" class="mb-6 animate-fade-in-up">
          <ol class="flex items-center gap-1.5 text-sm text-gray-500 dark:text-gray-400">
            <li><a href="/" class="hover:text-gray-900 dark:text-gray-100 transition-colors">Accueil</a></li>
            <li aria-hidden="true" class="text-gray-300 dark:text-gray-600">/</li>
            <li><a href="/#apps" class="hover:text-gray-900 dark:text-gray-100 transition-colors">Applications</a></li>
            <li aria-hidden="true" class="text-gray-300 dark:text-gray-600">/</li>
            <li aria-current="page" class="text-gray-900 dark:text-gray-100 font-medium truncate" id="app-breadcrumb">{app.name}</li>
          </ol>
        </nav>

        <div class="animate-fade-in-up delay-100 flex items-center gap-3 mb-6">
          {app.iconSvgPath && (
            <div class={`inline-flex items-center justify-center w-14 h-14 bg-gradient-to-br ${c.from} ${c.to} rounded-2xl shadow-lg ${c.shadow}`}>
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={app.iconSvgPath} />
              </svg>
            </div>
          )}
          <span id="app-code" class={`text-xs font-mono px-2 py-1 ${c.bg} ${c.text} rounded`}>{app.code}</span>
        </div>

        <h1 id="app-name" class="animate-fade-in-up delay-200 text-5xl md:text-7xl font-extrabold text-gray-900 dark:text-gray-100 tracking-tight leading-[1.05] mb-4">
          {app.name}
        </h1>

        <p id="app-tagline" class={`animate-fade-in-up delay-300 text-2xl md:text-3xl ${c.text} font-display-italic mb-6 ${app.tagline ? '' : 'hidden'}`}>
          {app.tagline}
        </p>

        <p id="app-description" class="animate-fade-in-up delay-400 text-lg text-gray-500 dark:text-gray-400 leading-relaxed mb-10 max-w-xl">
          {app.longDescription || app.description}
        </p>

        <div class="animate-fade-in-up delay-500 flex flex-col sm:flex-row gap-3">
          <a href="/contact" class={`inline-flex items-center justify-center gap-2 bg-gradient-to-r ${c.fromDark} ${c.toDark} text-white px-6 py-3.5 rounded-full font-semibold hover:shadow-xl ${c.shadow} transition-all duration-300 hover:-translate-y-0.5`}>
            Demander une démo gratuite
          </a>
          {app.apkUrl && (
            <a id="apk-download" href={app.apkUrl} class="group inline-flex items-center justify-center gap-2 glass-strong text-gray-700 dark:text-gray-200 px-6 py-3.5 rounded-full font-semibold hover:bg-white dark:bg-gray-900 transition-all duration-300 hover:-translate-y-0.5">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
              </svg>
              Télécharger l'APK <span id="apk-version" class="text-xs text-gray-400 dark:text-gray-500">{app.apkVersion && `v${app.apkVersion}`}</span>
            </a>
          )}
        </div>
      </div>

      <!-- Phone mockup app-spécifique -->
      <div class="relative flex justify-center items-center animate-scale-in delay-300">
        <div class={`absolute inset-0 bg-gradient-to-br ${c.bgSoft} via-white/20 to-transparent rounded-full blur-3xl`}></div>
        <div class="relative">
          <PhoneMockup variant={mockupVariant} />
        </div>
      </div>
    </div>
  </section>

  {/* Features */}
  {app.features && app.features.length > 0 && (
    <section class="relative py-28 overflow-hidden">
      <div class="absolute inset-0 -z-10 bg-mesh-soft"></div>
      <div class="max-w-6xl mx-auto px-6">
        <div class="reveal text-center mb-16">
          <span class={`inline-block text-sm font-semibold ${c.text} mb-3 uppercase tracking-wider`}>Fonctionnalités</span>
          <h2 class="text-4xl md:text-5xl font-extrabold text-gray-900 dark:text-gray-100 mb-4 tracking-tight">
            Les fonctionnalités de<br/>
            <span class="font-display-italic text-gray-500 dark:text-gray-400" id="app-name-features">{app.name}</span>
          </h2>
        </div>
        <div id="features-grid" class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {app.features.map((feature, i) => (
            <div class="reveal card-premium bg-white dark:bg-gray-900 rounded-2xl p-7 border border-gray-100 dark:border-gray-800 shadow-sm" style={`transition-delay: ${i * 70}ms`}>
              <div class={`w-12 h-12 bg-gradient-to-br ${c.from} ${c.to} rounded-xl flex items-center justify-center mb-5 shadow-lg ${c.shadow}`}>
                {feature.iconSvgPath && (
                  <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={feature.iconSvgPath} />
                  </svg>
                )}
              </div>
              <h3 class="font-bold text-gray-900 dark:text-gray-100 mb-2 text-lg">{feature.title}</h3>
              <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed">{feature.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* Download + QR */}
  {app.qrcodeUrl && (
    <section class="relative py-24 bg-gradient-to-br from-gray-50 to-white overflow-hidden">
      <div class="max-w-4xl mx-auto px-6">
        <div class="reveal-scale glass-strong rounded-3xl p-8 md:p-12 flex flex-col md:flex-row items-center gap-8 shadow-xl shadow-gray-200/50">
          <div class="flex-shrink-0 relative">
            <div class={`absolute inset-0 bg-gradient-to-br ${c.bgSoft} to-transparent rounded-2xl blur-xl`}></div>
            <img id="apk-qrcode" src={app.qrcodeUrl} alt={`QR Code - Télécharger ${app.name}`} class="relative w-40 h-40 bg-white dark:bg-gray-900 p-3 rounded-2xl shadow-lg" />
          </div>
          <div class="text-center md:text-left flex-1">
            <span class={`inline-block text-sm font-semibold ${c.text} mb-2 uppercase tracking-wider`}>Installation</span>
            <h2 class="font-extrabold text-gray-900 dark:text-gray-100 mb-2 text-3xl tracking-tight">
              Installer <span class="font-display-italic text-gray-500 dark:text-gray-400" id="app-name-install">{app.name}</span> sur Android
            </h2>
            <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed mb-4">
              Scannez le QR code avec votre appareil Android ou téléchargez directement l'APK. Pas de Play Store — installation directe.
            </p>
            {app.apkVersion && (
              <div class="inline-flex items-center gap-2 text-xs text-gray-500 dark:text-gray-400 mb-4">
                <span class={`inline-block w-2 h-2 rounded-full ${c.accent}`}></span>
                <span id="apk-version-badge">Dernière version : <strong class="text-gray-900 dark:text-gray-100">v{app.apkVersion}</strong></span>
              </div>
            )}
            {app.apkUrl && (
              <a id="apk-download-2" href={app.apkUrl} class={`inline-flex items-center gap-2 bg-gradient-to-r ${c.fromDark} ${c.toDark} text-white px-6 py-2.5 rounded-full text-sm font-semibold hover:shadow-lg ${c.shadow} transition-all duration-300 hover:-translate-y-0.5`}>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                </svg>
                Télécharger l'APK
              </a>
            )}
          </div>
        </div>

        {/* Notes de version */}
        <div id="apk-release-notes-block" class={`mt-6 rounded-2xl ${c.bg} border ${c.border} p-6 ${app.apkReleaseNotes ? '' : 'hidden'}`}>
          <div class="flex items-center gap-2 mb-3">
            <div class={`w-8 h-8 rounded-lg bg-gradient-to-br ${c.from} ${c.to} flex items-center justify-center`}>
              <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
            </div>
            <h4 class="font-bold text-gray-900 dark:text-gray-100 text-sm">Nouveautés de cette version</h4>
            {app.apkVersion && <span class={`text-xs font-mono ${c.text} ml-auto`}>v{app.apkVersion}</span>}
          </div>
          <p id="apk-release-notes" class="text-sm text-gray-700 dark:text-gray-200 leading-relaxed whitespace-pre-line">{app.apkReleaseNotes}</p>
        </div>
      </div>
    </section>
  )}

  {/* Pricing */}
  {app.pricingPlans && app.pricingPlans.length > 0 && (
    <section class="relative py-28 overflow-hidden">
      <div class="max-w-6xl mx-auto px-6">
        <div class="reveal text-center mb-16">
          <span class={`inline-block text-sm font-semibold ${c.text} mb-3 uppercase tracking-wider`}>Tarifs</span>
          <h2 class="text-4xl md:text-5xl font-extrabold text-gray-900 dark:text-gray-100 mb-4 tracking-tight">
            Tarifs <span class="font-display-italic text-gray-500 dark:text-gray-400" id="app-name-pricing">{app.name}</span> —<br/>
            choisissez votre formule.
          </h2>
          <p class="text-lg text-gray-500 dark:text-gray-400 max-w-2xl mx-auto">
            Tarifs indicatifs HT, facturation mensuelle. Contactez-nous pour un devis personnalisé.
          </p>
        </div>

        <div id="pricing-grid" class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
          {app.pricingPlans.map((plan, i) => (
            <div
              class={`reveal relative bg-white dark:bg-gray-900 rounded-3xl p-8 ${plan.isFeatured ? `${c.border} ring-4 ${c.ring} shadow-2xl ${c.shadow}` : 'border border-gray-100 dark:border-gray-800 shadow-sm'}`}
              style={`transition-delay: ${i * 100}ms`}
            >
              {plan.isFeatured && (
                <div class={`absolute top-0 right-6 -translate-y-1/2 bg-gradient-to-r ${c.fromDark} ${c.toDark} text-white text-xs font-bold px-3 py-1.5 rounded-full shadow-lg`}>
                  ⭐ Recommandé
                </div>
              )}
              <h3 class="font-extrabold text-gray-900 dark:text-gray-100 text-2xl mb-2 tracking-tight">{plan.name}</h3>
              <div class="flex items-baseline gap-1 mb-6">
                <span class="text-5xl font-extrabold text-gray-900 dark:text-gray-100 tracking-tight">{plan.price}</span>
                {plan.period && <span class="text-gray-500 dark:text-gray-400 text-sm">{plan.period}</span>}
              </div>
              <ul class="space-y-3 mb-8">
                {(Array.isArray(plan.features) ? plan.features : []).map((feat) => (
                  <li class="flex items-start gap-2 text-sm text-gray-600 dark:text-gray-300">
                    <div class={`flex-shrink-0 w-5 h-5 ${c.bg} rounded-full flex items-center justify-center mt-0.5`}>
                      <svg class={`w-3 h-3 ${c.text}`} fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                      </svg>
                    </div>
                    {feat}
                  </li>
                ))}
              </ul>
              <a href="/contact" class={plan.isFeatured
                ? `block text-center bg-gradient-to-r ${c.fromDark} ${c.toDark} text-white px-6 py-3 rounded-full font-semibold hover:shadow-lg ${c.shadow} transition-all duration-300`
                : `block text-center glass-strong text-gray-700 dark:text-gray-200 px-6 py-3 rounded-full font-semibold hover:bg-white dark:bg-gray-900 transition-all duration-300`}>
                {plan.ctaLabel || 'Demander une démo'}
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* Découvrez aussi — cross-linking pour SEO + rétention */}
  {otherApps.length > 0 && (
    <section class="relative py-24 bg-gray-50/50 overflow-hidden">
      <div class="max-w-6xl mx-auto px-6">
        <div class="reveal text-center mb-12">
          <span class={`inline-block text-sm font-semibold ${c.text} mb-3 uppercase tracking-wider`}>Complétez avec</span>
          <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-gray-100 tracking-tight">
            Découvrez aussi<br/>
            <span class="font-display-italic text-gray-500 dark:text-gray-400">les autres apps de la suite.</span>
          </h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
          {otherApps.map((other) => {
            const oc = COLOR_CLASSES[other.color] || COLOR_CLASSES.blue;
            return (
              <a
                href={`/apps/${other.slug}`}
                class="reveal card-premium group relative overflow-hidden glass-strong rounded-2xl p-6 block"
              >
                <div class={`absolute -top-16 -right-16 w-48 h-48 bg-gradient-to-br ${oc.mesh} to-transparent rounded-full blur-3xl opacity-60 group-hover:opacity-100 transition-opacity`}></div>
                <div class="relative z-10">
                  <div class={`inline-flex w-10 h-10 bg-gradient-to-br ${oc.from} ${oc.to} rounded-xl items-center justify-center mb-3 shadow-lg`}>
                    {other.iconSvgPath && (
                      <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={other.iconSvgPath} />
                      </svg>
                    )}
                  </div>
                  <h3 class="font-extrabold text-gray-900 dark:text-gray-100 text-lg tracking-tight mb-1">{other.name}</h3>
                  {other.tagline && <p class={`text-xs font-semibold ${oc.text} mb-2`}>{other.tagline}</p>}
                  <p class="text-xs text-gray-500 dark:text-gray-400 leading-relaxed line-clamp-2 mb-3">{other.description}</p>
                  <span class={`inline-flex items-center gap-1 text-xs font-semibold ${oc.text} group-hover:gap-2 transition-all`}>
                    Découvrir
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                  </span>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  {/* CTA */}
  <section class="py-28">
    <div class="max-w-5xl mx-auto px-6">
      <div class={`reveal-scale relative overflow-hidden bg-gray-900 rounded-3xl p-12 md:p-20 text-center bg-noise`}>
        <div class="absolute inset-0 -z-10">
          <div class={`absolute top-0 right-0 w-[500px] h-[500px] bg-gradient-to-br ${c.bgSoft} to-transparent rounded-full blur-3xl animate-aurora`}></div>
          <div class={`absolute bottom-0 left-0 w-[400px] h-[400px] bg-gradient-to-tr ${c.bgSoft} to-transparent rounded-full blur-3xl animate-aurora`} style="animation-delay: -6s"></div>
        </div>

        <div class="relative z-10">
          <span class="inline-block text-sm font-semibold text-white/70 mb-3 uppercase tracking-wider">Démarrez aujourd'hui</span>
          <h2 class="text-4xl md:text-6xl font-extrabold text-white mb-6 tracking-tight leading-[1.1]">
            Prêt à essayer<br/>
            <span class="font-display-italic text-white/80"><span id="app-name-cta">{app.name}</span> ?</span>
          </h2>
          <p class="text-lg text-white/70 mb-10 max-w-xl mx-auto">
            Demandez une démonstration gratuite personnalisée sur votre métier et vos données.
          </p>
          <a href="/contact" class="inline-flex items-center gap-2 bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 px-8 py-4 rounded-full font-semibold hover:shadow-2xl transition-all duration-300 hover:-translate-y-0.5">
            Demander une démo gratuite
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* Rafraîchir descriptions + APK/QR + features + pricing au runtime */}
  <script define:vars={{ API_URL, slug: app.slug, colorClasses: c }}>
    (async () => {
      const escapeHtml = (s) => String(s ?? '').replace(/[&<>"']/g, (m) => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[m]));

      try {
        const res = await fetch(`${API_URL}/api/apps/${slug}`, { cache: 'no-store' });
        if (!res.ok) return;
        const data = await res.json();
        const c = colorClasses;

        // ── Hero ──────────────────────────────────────────────────────────
        const name = document.getElementById('app-name');
        const nameCta = document.getElementById('app-name-cta');
        const nameBreadcrumb = document.getElementById('app-breadcrumb');
        const nameFeatures = document.getElementById('app-name-features');
        const nameInstall = document.getElementById('app-name-install');
        const namePricing = document.getElementById('app-name-pricing');
        const code = document.getElementById('app-code');
        const tagline = document.getElementById('app-tagline');
        const description = document.getElementById('app-description');
        if (name && data.name) name.textContent = data.name;
        if (nameCta && data.name) nameCta.textContent = data.name;
        if (nameBreadcrumb && data.name) nameBreadcrumb.textContent = data.name;
        if (nameFeatures && data.name) nameFeatures.textContent = data.name;
        if (nameInstall && data.name)  nameInstall.textContent = data.name;
        if (namePricing && data.name)  namePricing.textContent = data.name;
        if (code && data.code) code.textContent = data.code;
        // Titre du navigateur
        if (data.name && data.tagline) document.title = `${data.name} — ${data.tagline}`;
        else if (data.name) document.title = `${data.name} — customApps`;
        if (tagline) {
          if (data.tagline) { tagline.textContent = data.tagline; tagline.classList.remove('hidden'); }
          else              { tagline.classList.add('hidden'); }
        }
        if (description) {
          const text = data.longDescription || data.description;
          if (text) description.textContent = text;
        }

        // ── APK / QR / version / notes ───────────────────────────────────
        const qr = document.getElementById('apk-qrcode');
        const link1 = document.getElementById('apk-download');
        const link2 = document.getElementById('apk-download-2');
        const version = document.getElementById('apk-version');
        const versionBadge = document.getElementById('apk-version-badge');
        const releaseNotes = document.getElementById('apk-release-notes');
        const releaseNotesBlock = document.getElementById('apk-release-notes-block');
        if (qr && data.qrcodeUrl) qr.src = data.qrcodeUrl;
        if (link1 && data.apkUrl) link1.href = data.apkUrl;
        if (link2 && data.apkUrl) link2.href = data.apkUrl;
        if (version && data.apkVersion) version.textContent = `v${data.apkVersion}`;
        if (versionBadge && data.apkVersion) {
          versionBadge.innerHTML = `Dernière version : <strong class="text-gray-900 dark:text-gray-100">v${escapeHtml(data.apkVersion)}</strong>`;
        }
        if (releaseNotes) {
          if (data.apkReleaseNotes) {
            releaseNotes.textContent = data.apkReleaseNotes;
            if (releaseNotesBlock) releaseNotesBlock.classList.remove('hidden');
          } else if (releaseNotesBlock) {
            releaseNotesBlock.classList.add('hidden');
          }
        }

        // ── Features ─────────────────────────────────────────────────────
        const featuresGrid = document.getElementById('features-grid');
        if (featuresGrid && Array.isArray(data.features)) {
          featuresGrid.innerHTML = data.features.map((f) => `
            <div class="card-premium bg-white dark:bg-gray-900 rounded-2xl p-7 border border-gray-100 dark:border-gray-800 shadow-sm">
              <div class="w-12 h-12 bg-gradient-to-br ${c.from} ${c.to} rounded-xl flex items-center justify-center mb-5 shadow-lg ${c.shadow}">
                ${f.iconSvgPath ? `<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="${escapeHtml(f.iconSvgPath)}"/></svg>` : ''}
              </div>
              <h3 class="font-bold text-gray-900 dark:text-gray-100 mb-2 text-lg">${escapeHtml(f.title)}</h3>
              <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed">${escapeHtml(f.description || '')}</p>
            </div>
          `).join('');
        }

        // ── Pricing plans ────────────────────────────────────────────────
        const pricingGrid = document.getElementById('pricing-grid');
        if (pricingGrid && Array.isArray(data.pricingPlans)) {
          pricingGrid.innerHTML = data.pricingPlans.map((p) => {
            const cardClasses = p.isFeatured
              ? `${c.border} ring-4 ${c.ring} shadow-2xl ${c.shadow}`
              : 'border border-gray-100 dark:border-gray-800 shadow-sm';
            const badge = p.isFeatured
              ? `<div class="absolute top-0 right-6 -translate-y-1/2 bg-gradient-to-r ${c.fromDark} ${c.toDark} text-white text-xs font-bold px-3 py-1.5 rounded-full shadow-lg">⭐ Recommandé</div>`
              : '';
            const featuresList = (Array.isArray(p.features) ? p.features : []).map((feat) => `
              <li class="flex items-start gap-2 text-sm text-gray-600 dark:text-gray-300">
                <div class="flex-shrink-0 w-5 h-5 ${c.bg} rounded-full flex items-center justify-center mt-0.5">
                  <svg class="w-3 h-3 ${c.text}" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                </div>
                ${escapeHtml(feat)}
              </li>
            `).join('');
            const ctaClass = p.isFeatured
              ? `block text-center bg-gradient-to-r ${c.fromDark} ${c.toDark} text-white px-6 py-3 rounded-full font-semibold hover:shadow-lg ${c.shadow} transition-all duration-300`
              : `block text-center glass-strong text-gray-700 dark:text-gray-200 px-6 py-3 rounded-full font-semibold hover:bg-white dark:bg-gray-900 transition-all duration-300`;
            return `
              <div class="relative bg-white dark:bg-gray-900 rounded-3xl p-8 ${cardClasses}">
                ${badge}
                <h3 class="font-extrabold text-gray-900 dark:text-gray-100 text-2xl mb-2 tracking-tight">${escapeHtml(p.name)}</h3>
                <div class="flex items-baseline gap-1 mb-6">
                  <span class="text-5xl font-extrabold text-gray-900 dark:text-gray-100 tracking-tight">${escapeHtml(p.price)}</span>
                  ${p.period ? `<span class="text-gray-500 dark:text-gray-400 text-sm">${escapeHtml(p.period)}</span>` : ''}
                </div>
                <ul class="space-y-3 mb-8">${featuresList}</ul>
                <a href="/contact" class="${ctaClass}">${escapeHtml(p.ctaLabel || 'Demander une démo')}</a>
              </div>
            `;
          }).join('');
        }
      } catch {}
    })();
  </script>
</Base>
