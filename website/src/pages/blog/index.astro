---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());

const CATEGORY_LABELS = {
  'guide': 'Guide',
  'actualites': 'Actualités',
  'etude-de-cas': 'Étude de cas',
  'produit': 'Produit',
  'sous-le-capot': 'Sous le capot',
};

const CATEGORY_COLORS = {
  'guide':          'bg-blue-50 text-blue-700',
  'actualites':     'bg-pink-50 text-pink-700',
  'etude-de-cas':   'bg-emerald-50 text-emerald-700',
  'produit':        'bg-violet-50 text-violet-700',
  'sous-le-capot':  'bg-orange-50 text-orange-700',
};

const featured = posts.find(p => p.data.featured) || posts[0];
const rest = posts.filter(p => p.id !== featured?.id);

const dateFormat = (d) => new Intl.DateTimeFormat('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' }).format(d);

const title = 'Blog customApps — digitalisation ERP, apps métier, WaveSoft';
const description = "Guides, actualités et retours d'expérience sur la digitalisation des processus terrain : force de vente mobile, achats, expéditions, sécurité des apps Android métier.";
---

<Base title={title} description={description}>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-noise">
    <div class="absolute inset-0 -z-10 bg-mesh-soft"></div>
    <div class="max-w-5xl mx-auto px-6 pt-16 md:pt-24 pb-12 text-center">
      <span class="inline-block text-sm font-semibold text-blue-600 mb-3 uppercase tracking-wider animate-fade-in-up">Le Blog</span>
      <h1 class="animate-fade-in-up delay-100 text-5xl md:text-6xl font-extrabold text-gray-900 tracking-tight leading-[1.05] mb-4">
        Digitaliser le <span class="font-display-italic text-gradient">terrain</span>,<br/>
        un article à la fois.
      </h1>
      <p class="animate-fade-in-up delay-200 text-lg text-gray-500 max-w-2xl mx-auto">
        Guides pratiques, retours d'expérience et décryptages techniques pour les PME qui équipent leurs équipes mobiles.
      </p>
    </div>
  </section>

  {posts.length === 0 && (
    <section class="py-24 text-center">
      <p class="text-gray-500">Les premiers articles arrivent bientôt. <a href="/contact" class="text-blue-600 font-semibold">Contactez-nous</a> pour suggérer un sujet.</p>
    </section>
  )}

  {featured && (
    <!-- Article mis en avant -->
    <section class="py-16">
      <div class="max-w-6xl mx-auto px-6">
        <a href={`/blog/${featured.id}`} class="reveal card-premium group block glass-strong rounded-3xl p-8 md:p-12 overflow-hidden relative">
          <div class="absolute -top-20 -right-20 w-96 h-96 bg-gradient-to-br from-blue-100/40 to-transparent rounded-full blur-3xl opacity-60 group-hover:opacity-100 transition-opacity"></div>
          <div class="relative z-10 grid md:grid-cols-3 gap-8 items-center">
            <div class="md:col-span-2">
              <div class="flex items-center gap-2 mb-4 flex-wrap">
                <span class="inline-block text-xs font-semibold px-2 py-1 rounded-full bg-blue-600 text-white uppercase tracking-wider">À la une</span>
                <span class={`inline-block text-xs font-semibold px-2 py-1 rounded-full ${CATEGORY_COLORS[featured.data.category] || CATEGORY_COLORS.guide}`}>
                  {CATEGORY_LABELS[featured.data.category] || 'Guide'}
                </span>
                <time class="text-xs text-gray-500" datetime={featured.data.publishedAt.toISOString()}>{dateFormat(featured.data.publishedAt)}</time>
              </div>
              <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 tracking-tight mb-3 group-hover:text-blue-600 transition-colors">
                {featured.data.title}
              </h2>
              <p class="text-gray-500 leading-relaxed mb-4">
                {featured.data.description}
              </p>
              <span class="inline-flex items-center gap-1 text-sm font-semibold text-blue-600 group-hover:gap-2 transition-all">
                Lire l'article
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </span>
            </div>
            <div class="hidden md:block text-right">
              <div class="inline-flex items-center justify-center w-24 h-24 bg-gradient-to-br from-blue-600 to-violet-600 rounded-3xl shadow-xl shadow-blue-500/20 text-white">
                <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
              </div>
            </div>
          </div>
        </a>
      </div>
    </section>
  )}

  {rest.length > 0 && (
    <!-- Articles suivants -->
    <section class="pb-28">
      <div class="max-w-6xl mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {rest.map((post, i) => (
            <a href={`/blog/${post.id}`} class="reveal card-premium group block bg-white rounded-2xl border border-gray-100 shadow-sm p-7 overflow-hidden" style={`transition-delay: ${i * 60}ms`}>
              <div class="flex items-center gap-2 mb-3 flex-wrap">
                <span class={`inline-block text-xs font-semibold px-2 py-0.5 rounded-full ${CATEGORY_COLORS[post.data.category] || CATEGORY_COLORS.guide}`}>
                  {CATEGORY_LABELS[post.data.category] || 'Guide'}
                </span>
                <time class="text-xs text-gray-400" datetime={post.data.publishedAt.toISOString()}>{dateFormat(post.data.publishedAt)}</time>
              </div>
              <h3 class="font-bold text-gray-900 text-lg tracking-tight mb-2 group-hover:text-blue-600 transition-colors line-clamp-2">
                {post.data.title}
              </h3>
              <p class="text-sm text-gray-500 leading-relaxed line-clamp-3 mb-4">
                {post.data.description}
              </p>
              <span class="inline-flex items-center gap-1 text-sm font-semibold text-blue-600 group-hover:gap-2 transition-all">
                Lire
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- RSS -->
  <section class="pb-16 text-center">
    <a href="/rss.xml" class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-blue-600 transition-colors">
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M6.503 20.752c0 1.794-1.456 3.248-3.251 3.248-1.796 0-3.252-1.454-3.252-3.248 0-1.794 1.456-3.248 3.252-3.248 1.795.001 3.251 1.454 3.251 3.248zm-6.503-12.572v4.811c6.05.062 10.96 4.966 11.022 11.009h4.817c-.062-8.71-7.118-15.758-15.839-15.82zm0-3.368c10.58.046 19.152 8.594 19.183 19.18h4.817c-.03-13.231-10.755-23.934-24-23.98v4.8z"/></svg>
      Flux RSS
    </a>
  </section>
</Base>
