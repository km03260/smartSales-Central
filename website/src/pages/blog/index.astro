---
import Base from '../../layouts/Base.astro';

const API_URL = import.meta.env.PUBLIC_API_URL || 'https://api.customapps.fr';

let posts = [];
try {
  const res = await fetch(`${API_URL}/api/blog`);
  if (res.ok) posts = await res.json();
} catch {}

const CATEGORY_LABELS = {
  'guide': 'Guide',
  'actualites': 'Actualités',
  'etude-de-cas': 'Étude de cas',
  'produit': 'Produit',
  'sous-le-capot': 'Sous le capot',
};

const CATEGORY_COLORS = {
  'guide':          'bg-blue-50 text-blue-700',
  'actualites':     'bg-pink-50 text-pink-700',
  'etude-de-cas':   'bg-emerald-50 text-emerald-700',
  'produit':        'bg-violet-50 text-violet-700',
  'sous-le-capot':  'bg-orange-50 text-orange-700',
};

const featured = posts.find(p => p.featured) || posts[0];
const rest = posts.filter(p => p.slug !== featured?.slug);

const dateFormat = (d) => new Intl.DateTimeFormat('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' }).format(new Date(d));

const title = 'Blog customApps — digitalisation ERP, apps métier, WaveSoft';
const description = "Guides, actualités et retours d'expérience sur la digitalisation des processus terrain : force de vente mobile, achats, expéditions, sécurité des apps Android métier.";
---

<Base title={title} description={description}>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-noise">
    <div class="absolute inset-0 -z-10 bg-mesh-soft"></div>
    <div class="max-w-5xl mx-auto px-6 pt-16 md:pt-24 pb-12 text-center">
      <span class="inline-block text-sm font-semibold text-blue-600 mb-3 uppercase tracking-wider animate-fade-in-up">Le Blog</span>
      <h1 class="animate-fade-in-up delay-100 text-5xl md:text-6xl font-extrabold text-gray-900 dark:text-gray-100 tracking-tight leading-[1.05] mb-4">
        Digitaliser le <span class="font-display-italic text-gradient">terrain</span>,<br/>
        un article à la fois.
      </h1>
      <p class="animate-fade-in-up delay-200 text-lg text-gray-500 dark:text-gray-300 max-w-2xl mx-auto">
        Guides pratiques, retours d'expérience et décryptages techniques pour les PME qui équipent leurs équipes mobiles.
      </p>
    </div>
  </section>

  <div id="blog-empty-state" class={`py-24 text-center ${posts.length === 0 ? '' : 'hidden'}`}>
    <p class="text-gray-500 dark:text-gray-300">Les premiers articles arrivent bientôt. <a href="/contact" class="text-blue-600 font-semibold">Contactez-nous</a> pour suggérer un sujet.</p>
  </div>

  <!-- Article mis en avant -->
  <section id="blog-featured-section" class={`py-16 ${featured ? '' : 'hidden'}`}>
    <div class="max-w-6xl mx-auto px-6">
      {featured && (
        <a id="blog-featured-link" href={`/blog/${featured.slug}`} class="reveal card-premium group block glass-strong rounded-3xl overflow-hidden relative">
          <div class="grid md:grid-cols-2 gap-0 items-stretch">
            {/* Cover image */}
            <div class="relative aspect-[16/9] md:aspect-auto md:min-h-[340px] overflow-hidden bg-gray-100 dark:bg-gray-800">
              <img id="blog-featured-cover" src={featured.coverImage || '/og-default.png'}
                alt={`Illustration — ${featured.title}`}
                class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            </div>
            {/* Texte */}
            <div class="p-8 md:p-10 flex flex-col justify-center">
              <div class="flex items-center gap-2 mb-4 flex-wrap">
                <span class="inline-block text-xs font-semibold px-2 py-1 rounded-full bg-blue-600 text-white uppercase tracking-wider">À la une</span>
                <span id="blog-featured-category" class={`inline-block text-xs font-semibold px-2 py-1 rounded-full ${CATEGORY_COLORS[featured.category] || CATEGORY_COLORS.guide}`}>
                  {CATEGORY_LABELS[featured.category] || 'Guide'}
                </span>
                <time id="blog-featured-date" class="text-xs text-gray-500 dark:text-gray-300" datetime={featured.publishedAt}>{dateFormat(featured.publishedAt)}</time>
              </div>
              <h2 id="blog-featured-title" class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-gray-100 tracking-tight mb-3 group-hover:text-blue-600 transition-colors">
                {featured.title}
              </h2>
              <p id="blog-featured-description" class="text-gray-500 dark:text-gray-300 leading-relaxed mb-4">
                {featured.description}
              </p>
              <span class="inline-flex items-center gap-1 text-sm font-semibold text-blue-600 group-hover:gap-2 transition-all">
                Lire l'article
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </span>
            </div>
          </div>
        </a>
      )}
    </div>
  </section>

  <!-- Articles suivants -->
  <section id="blog-rest-section" class={`pb-28 ${rest.length > 0 ? '' : 'hidden'}`}>
    <div class="max-w-6xl mx-auto px-6">
      <div id="blog-rest-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {rest.map((post, i) => (
          <a href={`/blog/${post.slug}`} class="card-premium group block bg-white dark:bg-gray-900 rounded-2xl border border-gray-100 dark:border-gray-700 shadow-sm overflow-hidden">
            {/* Cover */}
            <div class="relative aspect-[16/9] overflow-hidden bg-gray-100 dark:bg-gray-800">
              <img src={post.coverImage || '/og-default.png'}
                alt={`Illustration — ${post.title}`}
                class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            </div>
            {/* Texte */}
            <div class="p-6">
              <div class="flex items-center gap-2 mb-3 flex-wrap">
                <span class={`inline-block text-xs font-semibold px-2 py-0.5 rounded-full ${CATEGORY_COLORS[post.category] || CATEGORY_COLORS.guide}`}>
                  {CATEGORY_LABELS[post.category] || 'Guide'}
                </span>
                <time class="text-xs text-gray-400 dark:text-gray-400" datetime={post.publishedAt}>{dateFormat(post.publishedAt)}</time>
              </div>
              <h3 class="font-bold text-gray-900 dark:text-gray-100 text-lg tracking-tight mb-2 group-hover:text-blue-600 transition-colors line-clamp-2">
                {post.title}
              </h3>
              <p class="text-sm text-gray-500 dark:text-gray-300 leading-relaxed line-clamp-3 mb-4">
                {post.description}
              </p>
              <span class="inline-flex items-center gap-1 text-sm font-semibold text-blue-600 group-hover:gap-2 transition-all">
                Lire
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- RSS -->
  <section class="pb-16 text-center">
    <a href="/rss.xml" class="inline-flex items-center gap-2 text-sm text-gray-500 dark:text-gray-300 hover:text-blue-600 transition-colors">
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M6.503 20.752c0 1.794-1.456 3.248-3.251 3.248-1.796 0-3.252-1.454-3.252-3.248 0-1.794 1.456-3.248 3.252-3.248 1.795.001 3.251 1.454 3.251 3.248zm-6.503-12.572v4.811c6.05.062 10.96 4.966 11.022 11.009h4.817c-.062-8.71-7.118-15.758-15.839-15.82zm0-3.368c10.58.046 19.152 8.594 19.183 19.18h4.817c-.03-13.231-10.755-23.934-24-23.98v4.8z"/></svg>
      Flux RSS
    </a>
  </section>

  <!-- Hydratation runtime : refetch et rebuild des 2 grilles pour refléter les ajouts/suppressions admin -->
  <script define:vars={{ API_URL, CATEGORY_LABELS, CATEGORY_COLORS }}>
    (async () => {
      const escapeHtml = (s) => String(s ?? '').replace(/[&<>"']/g, (m) => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[m]));
      const fmt = (d) => new Intl.DateTimeFormat('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' }).format(new Date(d));

      try {
        const res = await fetch(`${API_URL}/api/blog`, { cache: 'no-store' });
        if (!res.ok) return;
        const posts = await res.json();
        if (!Array.isArray(posts)) return;

        const empty = document.getElementById('blog-empty-state');
        const featuredSection = document.getElementById('blog-featured-section');
        const restSection = document.getElementById('blog-rest-section');
        const restGrid = document.getElementById('blog-rest-grid');

        if (posts.length === 0) {
          empty?.classList.remove('hidden');
          featuredSection?.classList.add('hidden');
          restSection?.classList.add('hidden');
          return;
        }
        empty?.classList.add('hidden');

        const featured = posts.find(p => p.featured) || posts[0];
        const rest = posts.filter(p => p.slug !== featured.slug);

        // Update featured block
        if (featured) {
          featuredSection?.classList.remove('hidden');
          const link = document.getElementById('blog-featured-link');
          const cover = document.getElementById('blog-featured-cover');
          const cat = document.getElementById('blog-featured-category');
          const date = document.getElementById('blog-featured-date');
          const title = document.getElementById('blog-featured-title');
          const desc = document.getElementById('blog-featured-description');
          if (link) link.href = `/blog/${featured.slug}`;
          if (cover) {
            cover.src = featured.coverImage || '/og-default.png';
            cover.alt = `Illustration — ${featured.title}`;
          }
          if (cat) {
            cat.textContent = CATEGORY_LABELS[featured.category] || 'Guide';
            cat.className = `inline-block text-xs font-semibold px-2 py-1 rounded-full ${CATEGORY_COLORS[featured.category] || CATEGORY_COLORS.guide}`;
          }
          if (date) { date.textContent = fmt(featured.publishedAt); date.setAttribute('datetime', featured.publishedAt); }
          if (title) title.textContent = featured.title;
          if (desc) desc.textContent = featured.description;
        }

        // Rebuild rest grid
        if (restGrid) {
          if (rest.length === 0) {
            restSection?.classList.add('hidden');
          } else {
            restSection?.classList.remove('hidden');
            restGrid.innerHTML = rest.map((post) => `
              <a href="/blog/${encodeURIComponent(post.slug)}" class="card-premium group block bg-white dark:bg-gray-900 rounded-2xl border border-gray-100 dark:border-gray-700 shadow-sm overflow-hidden">
                <div class="relative aspect-[16/9] overflow-hidden bg-gray-100 dark:bg-gray-800">
                  <img src="${escapeHtml(post.coverImage || '/og-default.png')}" alt="Illustration — ${escapeHtml(post.title)}"
                    class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                </div>
                <div class="p-6">
                  <div class="flex items-center gap-2 mb-3 flex-wrap">
                    <span class="inline-block text-xs font-semibold px-2 py-0.5 rounded-full ${CATEGORY_COLORS[post.category] || CATEGORY_COLORS.guide}">
                      ${escapeHtml(CATEGORY_LABELS[post.category] || 'Guide')}
                    </span>
                    <time class="text-xs text-gray-400 dark:text-gray-400" datetime="${escapeHtml(post.publishedAt)}">${escapeHtml(fmt(post.publishedAt))}</time>
                  </div>
                  <h3 class="font-bold text-gray-900 dark:text-gray-100 text-lg tracking-tight mb-2 group-hover:text-blue-600 transition-colors line-clamp-2">${escapeHtml(post.title)}</h3>
                  <p class="text-sm text-gray-500 dark:text-gray-300 leading-relaxed line-clamp-3 mb-4">${escapeHtml(post.description)}</p>
                  <span class="inline-flex items-center gap-1 text-sm font-semibold text-blue-600 group-hover:gap-2 transition-all">
                    Lire
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                  </span>
                </div>
              </a>
            `).join('');
          }
        }
      } catch {}
    })();
  </script>
</Base>
