---
import Base from '../../layouts/Base.astro';
import { marked } from 'marked';

const API_URL = import.meta.env.PUBLIC_API_URL || 'https://api.customapps.fr';

export async function getStaticPaths() {
  const API_URL = import.meta.env.PUBLIC_API_URL || 'https://api.customapps.fr';
  try {
    const res = await fetch(`${API_URL}/api/blog`);
    if (res.ok) {
      const posts = await res.json();
      if (Array.isArray(posts) && posts.length > 0) {
        return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
      }
    }
  } catch {}
  // Fallback : au moins une page pour éviter un build vide
  return [{ params: { slug: 'placeholder' }, props: { post: null } }];
}

const { slug } = Astro.params;
let { post } = Astro.props;

// Si pas de post au build, on essaye encore au render time
if (!post) {
  try {
    const res = await fetch(`${API_URL}/api/blog/${slug}`);
    if (res.ok) post = await res.json();
  } catch {}
}

// 404 si vraiment rien
if (!post) {
  return new Response(null, { status: 404, statusText: 'Not found' });
}

// Le contenu est désormais stocké en HTML (éditeur RichEditor TipTap).
// Fallback : si un ancien article est encore en markdown (ne commence pas par un tag HTML),
// on le convertit au vol via `marked` pour la rétro-compat.
function resolveContent(raw) {
  const s = String(raw || '').trim();
  if (!s) return '';
  if (/^<(p|h[1-6]|ul|ol|blockquote|div|strong|em|table|section|article|figure|pre)\b/i.test(s)) {
    return s;
  }
  return marked.parse(s, { breaks: false, gfm: true });
}
const renderedHtml = resolveContent(post.content);

const CATEGORY_LABELS = {
  'guide': 'Guide',
  'actualites': 'Actualités',
  'etude-de-cas': 'Étude de cas',
  'produit': 'Produit',
  'sous-le-capot': 'Sous le capot',
};
const CATEGORY_COLORS = {
  'guide':          'bg-blue-50 text-blue-700',
  'actualites':     'bg-pink-50 text-pink-700',
  'etude-de-cas':   'bg-emerald-50 text-emerald-700',
  'produit':        'bg-violet-50 text-violet-700',
  'sous-le-capot':  'bg-orange-50 text-orange-700',
};

const dateFormat = (d) => new Intl.DateTimeFormat('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' }).format(new Date(d));

// Articles suggérés : même catégorie, complétés par d'autres si pas assez
let allPosts = [];
try {
  const resAll = await fetch(`${API_URL}/api/blog`);
  if (resAll.ok) allPosts = await resAll.json();
} catch {}

const others = allPosts.filter(p => p.slug !== post.slug);
const sameCat = others.filter(p => p.category === post.category).slice(0, 2);
const suggested = sameCat.length >= 2 ? sameCat : [...sameCat, ...others.filter(p => !sameCat.includes(p)).slice(0, 2 - sameCat.length)];

const canonicalUrl = new URL(`/blog/${post.slug}/`, Astro.site).href;

const blogPostingSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.title,
  "description": post.description,
  "datePublished": new Date(post.publishedAt).toISOString(),
  ...(post.updatedAt ? { "dateModified": new Date(post.updatedAt).toISOString() } : {}),
  "author": {
    "@type": "Organization",
    "name": post.author || "customApps",
    "url": "https://customapps.fr",
  },
  "publisher": {
    "@type": "Organization",
    "name": "customApps",
    "url": "https://customapps.fr",
    "logo": { "@type": "ImageObject", "url": "https://customapps.fr/og-default.png" },
  },
  "mainEntityOfPage": { "@type": "WebPage", "@id": canonicalUrl },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://customapps.fr/" },
    { "@type": "ListItem", "position": 2, "name": "Blog",    "item": "https://customapps.fr/blog/" },
    { "@type": "ListItem", "position": 3, "name": post.title, "item": canonicalUrl },
  ],
};
---

<Base title={`${post.title} | Blog customApps`} description={post.description}>
  <script type="application/ld+json" set:html={JSON.stringify(blogPostingSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <article class="relative overflow-hidden">
    <div class="absolute inset-0 -z-10">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-gradient-to-br from-blue-100/40 via-violet-100/30 to-transparent rounded-full blur-3xl"></div>
    </div>

    <header class="max-w-3xl mx-auto px-6 pt-12 md:pt-16 pb-8">
      <nav aria-label="Fil d'ariane" class="mb-6">
        <ol class="flex items-center gap-1.5 text-sm text-gray-500 dark:text-gray-400 flex-wrap">
          <li><a href="/" class="hover:text-gray-900 dark:text-gray-100 transition-colors">Accueil</a></li>
          <li aria-hidden="true" class="text-gray-300 dark:text-gray-600">/</li>
          <li><a href="/blog" class="hover:text-gray-900 dark:text-gray-100 transition-colors">Blog</a></li>
          <li aria-hidden="true" class="text-gray-300 dark:text-gray-600">/</li>
          <li aria-current="page" class="text-gray-900 dark:text-gray-100 font-medium truncate">{post.title}</li>
        </ol>
      </nav>

      <div class="flex items-center gap-2 mb-6 flex-wrap">
        <span class={`inline-block text-xs font-semibold px-2 py-1 rounded-full ${CATEGORY_COLORS[post.category] || CATEGORY_COLORS.guide}`}>
          {CATEGORY_LABELS[post.category] || 'Guide'}
        </span>
        <time class="text-sm text-gray-500 dark:text-gray-400" datetime={new Date(post.publishedAt).toISOString()}>Publié le {dateFormat(post.publishedAt)}</time>
      </div>

      <h1 class="text-4xl md:text-6xl font-extrabold text-gray-900 dark:text-gray-100 tracking-tight leading-[1.1] mb-6">
        {post.title}
      </h1>
      <p class="text-xl text-gray-500 dark:text-gray-400 leading-relaxed mb-6">
        {post.description}
      </p>

      <div class="flex items-center gap-3 text-sm text-gray-500 dark:text-gray-400">
        <div class="w-10 h-10 rounded-full bg-gradient-to-br from-blue-600 to-violet-600 flex items-center justify-center text-white font-bold text-sm">
          {post.author?.split(' ').map(s => s[0]).join('').slice(0, 2).toUpperCase() || 'CA'}
        </div>
        <span>Par <strong class="text-gray-900 dark:text-gray-100 font-semibold">{post.author || 'Équipe customApps'}</strong></span>
      </div>
    </header>

    {post.coverImage && (
      <div class="max-w-5xl mx-auto px-6 py-8">
        <div class="relative rounded-3xl overflow-hidden shadow-2xl shadow-blue-500/10 bg-gray-100 dark:bg-gray-800 aspect-[1200/630]">
          <img src={post.coverImage} alt={`Illustration — ${post.title}`} class="absolute inset-0 w-full h-full object-cover" />
        </div>
      </div>
    )}

    <div class="max-w-3xl mx-auto px-6 py-8">
      <div class="prose prose-lg prose-gray max-w-none
                  prose-headings:font-extrabold prose-headings:tracking-tight prose-headings:text-gray-900 dark:text-gray-100
                  prose-h2:text-3xl prose-h2:mt-12 prose-h2:mb-4
                  prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
                  prose-p:text-gray-600 dark:text-gray-300 prose-p:leading-relaxed
                  prose-a:text-blue-600 prose-a:font-semibold prose-a:no-underline hover:prose-a:underline
                  prose-strong:text-gray-900 dark:text-gray-100
                  prose-blockquote:border-l-blue-500 prose-blockquote:bg-blue-50/50 prose-blockquote:py-1 prose-blockquote:px-4 prose-blockquote:rounded-r-lg prose-blockquote:not-italic
                  prose-code:text-blue-600 prose-code:bg-blue-50 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:font-mono prose-code:text-sm prose-code:font-medium prose-code:before:hidden prose-code:after:hidden
                  prose-table:text-sm
                  prose-th:bg-gray-50 dark:bg-gray-950 prose-th:font-semibold
                  prose-ul:my-4 prose-li:text-gray-600 dark:text-gray-300 prose-li:my-1
                  prose-hr:border-gray-200 dark:border-gray-700" set:html={renderedHtml}></div>
    </div>

    {post.tags && post.tags.length > 0 && (
      <div class="max-w-3xl mx-auto px-6 py-8 border-t border-gray-100 dark:border-gray-800">
        <div class="flex items-center gap-2 flex-wrap">
          <span class="text-sm font-semibold text-gray-700 dark:text-gray-200">Tags :</span>
          {post.tags.map(tag => (
            <span class="text-xs px-3 py-1 bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 rounded-full">#{tag}</span>
          ))}
        </div>
      </div>
    )}
  </article>

  {suggested.length > 0 && (
    <section class="py-16 bg-gray-50/50">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-2xl md:text-3xl font-extrabold text-gray-900 dark:text-gray-100 tracking-tight mb-8 text-center">
          À lire également
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {suggested.map((p) => (
            <a href={`/blog/${p.slug}`} class="card-premium group block bg-white dark:bg-gray-900 rounded-2xl border border-gray-100 dark:border-gray-800 shadow-sm overflow-hidden">
              {p.coverImage && (
                <div class="relative aspect-[16/9] overflow-hidden bg-gray-100 dark:bg-gray-800">
                  <img src={p.coverImage} alt={`Illustration — ${p.title}`}
                    class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                </div>
              )}
              <div class="p-6">
                <div class="flex items-center gap-2 mb-3 flex-wrap">
                  <span class={`inline-block text-xs font-semibold px-2 py-0.5 rounded-full ${CATEGORY_COLORS[p.category] || CATEGORY_COLORS.guide}`}>
                    {CATEGORY_LABELS[p.category] || 'Guide'}
                  </span>
                  <time class="text-xs text-gray-400 dark:text-gray-500" datetime={new Date(p.publishedAt).toISOString()}>{dateFormat(p.publishedAt)}</time>
                </div>
                <h3 class="font-bold text-gray-900 dark:text-gray-100 text-lg tracking-tight mb-2 group-hover:text-blue-600 transition-colors line-clamp-2">
                  {p.title}
                </h3>
                <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed line-clamp-2">
                  {p.description}
                </p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="py-24">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-gray-100 tracking-tight mb-4">
        Envie d'équiper <span class="font-display-italic text-gray-500 dark:text-gray-400">vos équipes terrain</span> ?
      </h2>
      <p class="text-lg text-gray-500 dark:text-gray-400 mb-8">Demandez une démonstration gratuite de la suite customApps.</p>
      <a href="/contact" class="inline-flex items-center gap-2 bg-gradient-to-r from-blue-600 to-violet-600 text-white px-8 py-3.5 rounded-full font-semibold hover:shadow-xl hover:shadow-blue-500/25 transition-all duration-300 hover:-translate-y-0.5">
        Demander une démo
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </section>
</Base>
