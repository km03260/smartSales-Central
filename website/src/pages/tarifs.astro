---
import Base from '../layouts/Base.astro';

const plans = [
  {
    name: "Starter",
    price: "200",
    period: "/an",
    description: "Pour les petites équipes de 1 à 3 commerciaux",
    features: [
      "Jusqu'à 3 appareils",
      "Catalogue produits",
      "Prise de commandes",
      "Mode hors-ligne",
      "Synchronisation ERP",
      "Support email",
    ],
    cta: "Choisir Starter",
    highlighted: false,
  },
  {
    name: "Professional",
    price: "380",
    period: "/an",
    badge: "Populaire",
    description: "Pour les équipes commerciales en croissance",
    features: [
      "Jusqu'à 10 appareils",
      "Tout Starter +",
      "Devis & PDF",
      "Tarifs clients spéciaux",
      "Historique factures & BL",
      "Articles favoris & 20/80",
      "Support prioritaire",
    ],
    cta: "Choisir Professional",
    highlighted: true,
  },
  {
    name: "Enterprise",
    price: "Sur mesure",
    period: "",
    description: "Pour les grandes organisations",
    features: [
      "Appareils illimités",
      "Tout Professional +",
      "Multi-sites",
      "Personnalisation avancée",
      "Formation sur site",
      "Support dédié",
      "SLA garanti",
    ],
    cta: "Nous contacter",
    highlighted: false,
  },
];
---

<Base title="Tarifs - SmartSales">
  <!-- Header -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 -z-10">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[400px] bg-gradient-to-br from-blue-100 via-violet-50 to-transparent rounded-full blur-3xl opacity-50"></div>
    </div>
    <div class="max-w-6xl mx-auto px-6 py-20 text-center">
      <span class="inline-block text-sm font-semibold text-blue-600 mb-3 uppercase tracking-wider">Tarifs</span>
      <h1 class="text-4xl md:text-5xl font-extrabold text-gray-900 mb-4 tracking-tight">Tarifs simples et transparents</h1>
      <p class="text-lg text-gray-500 max-w-2xl mx-auto leading-relaxed">
        Choisissez le plan adapté à la taille de votre équipe commerciale. Tous les plans incluent la synchronisation ERP et le mode hors-ligne.
      </p>
    </div>
  </section>

  <!-- Pricing cards -->
  <section class="max-w-5xl mx-auto px-6 pb-24">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {plans.map((plan) => (
        <div class={`relative card-hover rounded-2xl p-8 ${
          plan.highlighted
            ? 'bg-gradient-to-br from-blue-600 via-blue-700 to-violet-700 text-white shadow-2xl shadow-blue-500/20 scale-105 z-10'
            : 'bg-white border border-gray-100 shadow-sm'
        }`}>
          {plan.badge && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2">
              <span class="bg-gradient-to-r from-amber-400 to-orange-400 text-white text-xs font-bold px-4 py-1 rounded-full shadow-lg">
                {plan.badge}
              </span>
            </div>
          )}
          <h2 class={`text-xl font-bold mb-2 ${plan.highlighted ? 'text-white' : 'text-gray-900'}`}>{plan.name}</h2>
          <p class={`text-sm mb-6 ${plan.highlighted ? 'text-blue-100' : 'text-gray-500'}`}>{plan.description}</p>
          <div class="mb-8">
            <span class={`text-5xl font-extrabold ${plan.highlighted ? 'text-white' : 'text-gray-900'}`}>
              {plan.price.includes('mesure') ? '' : ''}{plan.price}
            </span>
            {plan.period && (
              <span class={`text-base ml-1 ${plan.highlighted ? 'text-blue-200' : 'text-gray-400'}`}>{plan.period}</span>
            )}
            {!plan.price.includes('mesure') && (
              <div class={`text-xs mt-1 ${plan.highlighted ? 'text-blue-200' : 'text-gray-400'}`}>par appareil</div>
            )}
          </div>
          <ul class="space-y-3 mb-8">
            {plan.features.map((feature) => (
              <li class="flex items-center gap-3 text-sm">
                <div class={`w-5 h-5 rounded-full flex items-center justify-center shrink-0 ${
                  plan.highlighted ? 'bg-white/20' : 'bg-blue-50'
                }`}>
                  <svg class={`w-3 h-3 ${plan.highlighted ? 'text-white' : 'text-blue-600'}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <span class={plan.highlighted ? 'text-blue-50' : 'text-gray-600'}>{feature}</span>
              </li>
            ))}
          </ul>
          <a href="/contact" class={`block text-center py-3 rounded-full font-semibold text-sm transition-all duration-300 hover:-translate-y-0.5 ${
            plan.highlighted
              ? 'bg-white text-blue-700 hover:shadow-xl'
              : 'bg-gradient-to-r from-blue-600 to-violet-600 text-white hover:shadow-lg hover:shadow-blue-500/25'
          }`}>
            {plan.cta}
          </a>
        </div>
      ))}
    </div>

    <div class="mt-12 text-center">
      <p class="text-sm text-gray-400">
        Tous les prix sont HT. Engagement annuel. Installation et formation incluses pour les plans Professional et Enterprise.
      </p>
    </div>

    <!-- FAQ or trust -->
    <div class="mt-20 grid grid-cols-1 md:grid-cols-3 gap-6">
      {[
        { title: "Sans engagement longue durée", desc: "Renouvellement annuel simple. Pas de frais cachés ni de surprise.", icon: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" },
        { title: "Installation incluse", desc: "Notre équipe vous accompagne dans la mise en place et la formation de vos commerciaux.", icon: "M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0z" },
        { title: "Satisfait ou remboursé", desc: "Testez SmartSales pendant 30 jours. Si vous n'êtes pas convaincu, on vous rembourse.", icon: "M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" },
      ].map(({ title, desc, icon }) => (
        <div class="text-center p-6">
          <div class="w-12 h-12 bg-blue-50 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={icon} />
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2">{title}</h3>
          <p class="text-sm text-gray-500">{desc}</p>
        </div>
      ))}
    </div>
  </section>
</Base>
