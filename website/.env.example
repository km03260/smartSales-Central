# URL publique de l'API customApps (utilisée au build + hydratation runtime du site)
PUBLIC_API_URL=https://api.customapps.fr

# Analytics Plausible (optionnel) — laisse vide pour désactiver le tracking
# Domaine à tracker (tel qu'enregistré dans ton compte Plausible)
# PUBLIC_PLAUSIBLE_DOMAIN=customapps.fr

# Si tu auto-héberges Plausible, override l'URL du script (sinon laisse vide)
# PUBLIC_PLAUSIBLE_SCRIPT=https://plausible.io/js/script.js
