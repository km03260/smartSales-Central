# Base de données
DATABASE_URL="mysql://customapps:MOT_DE_PASSE@db:3306/customapps_central"

# Serveur
PORT=3500
NODE_ENV=production

# Domaine principal (utilisé par docker-compose pour les labels traefik)
DOMAIN=customapps.fr

# URL publique de l'API (utilisée pour les QR codes et liens de téléchargement APK)
PUBLIC_API_URL="https://api.customapps.fr"

# Secret JWT admin (générer avec: openssl rand -hex 32)
ADMIN_JWT_SECRET="change-this-to-a-secure-random-string"

# Clés RSA licence
LICENSE_PRIVATE_KEY_PATH="./keys/private.pem"
LICENSE_PUBLIC_KEY_PATH="./keys/public.pem"

# MariaDB (base créée dans le stack MariaDB existant, accessible via le network dbtesting, host: db)
# Créer la base et l'utilisateur manuellement :
# CREATE DATABASE customapps_central;
# CREATE USER 'customapps'@'%' IDENTIFIED BY 'MOT_DE_PASSE';
# GRANT ALL ON customapps_central.* TO 'customapps'@'%';

# SMTP (alertes email d'expiration de licence)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@customapps.fr
SMTP_PASS=your-smtp-password
SMTP_FROM="customApps <noreply@customapps.fr>"

# Email destinataire des notifications de contact (séparer par virgule si plusieurs)
CONTACT_NOTIFY_EMAIL="contact@customapps.fr"
