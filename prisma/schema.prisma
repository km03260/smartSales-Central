generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Applications (SmartSales, SmartExpeditions, etc.) ──────────────────────

model App {
  id          String   @id @default(uuid()) @db.VarChar(36)
  code        String   @unique @db.VarChar(10) // "SS", "SE", "SA"
  name        String   @db.VarChar(100) // "SmartSales", "SmartExpeditions"
  description String   @default("") @db.VarChar(500)
  isActive    Boolean  @default(true)
  apkFileName String   @default("") @db.VarChar(200)
  apkVersion  String   @default("") @db.VarChar(50)
  apkUpdatedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  licenses    License[]

  @@map("apps")
}

// ─── Entreprises clientes (acheteurs de SmartSales) ─────────────────────────

model Company {
  id           String   @id @default(uuid()) @db.VarChar(36)
  name         String   @db.VarChar(200)
  legalName    String   @db.VarChar(200)
  contactEmail String   @db.VarChar(200)
  contactPhone String   @default("") @db.VarChar(50)
  address      String   @default("") @db.VarChar(500)
  siret        String   @default("") @db.VarChar(20)
  notes        String   @default("") @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  licenses     License[]
  config       CompanyConfig?
  deployments  SyncServiceDeployment[]

  @@map("companies")
}

// ─── Licences ───────────────────────────────────────────────────────────────

model License {
  id             String   @id @default(uuid()) @db.VarChar(36)
  appId          String   @db.VarChar(36)
  companyId      String   @db.VarChar(36)
  deploymentId   String   @db.VarChar(36)                   // Déploiement SyncService (obligatoire — URLs/apiKey héritées)
  licenseKey     String   @unique @db.VarChar(20)           // {APP_CODE}-XXXX-XXXX-XXXX
  maxDevices     Int      @default(5)                       // Global à la licence (toutes bases confondues)
  features       Json     // ["orders","quotations","invoices","stats"]
  plan           String   @default("professional") @db.VarChar(50)
  startsAt       DateTime @default(now())
  expiresAt      DateTime
  isActive       Boolean  @default(true)
  isBlocked      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  app            App               @relation(fields: [appId], references: [id], onDelete: Cascade)
  company        Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  deployment     SyncServiceDeployment @relation(fields: [deploymentId], references: [id], onDelete: Restrict)
  devices        DeviceActivation[]
  usageLogs      UsageLog[]
  alerts         LicenseAlert[]
  instances      LicenseSqlInstance[]

  @@unique([appId, companyId]) // 1 seule licence par (application × client)
  @@map("licenses")
}

// ─── Déploiement SyncService (1 installation Windows physique) ─────────────
// Regroupe plusieurs licences qui partagent le même service Windows.
// Contient la configuration "partagée" (HTTPS, Kestrel, EDI, sync settings,
// connexion SQL par défaut, clé API).

model SyncServiceDeployment {
  id                     String   @id @default(uuid()) @db.VarChar(36)
  companyId              String   @db.VarChar(36)
  name                   String   @db.VarChar(200)            // ex: "Serveur principal Maurer"
  publicUrl              String   @db.VarChar(500)            // ex: https://213.56.180.33
  localUrl               String   @default("") @db.VarChar(500)
  apiKey                 String   @db.VarChar(200)            // partagée par toutes les licences du déploiement

  // Connexion SQL Server par défaut (utilisée si pas d'override par licence)
  sqlHost                String   @default("") @db.VarChar(200)
  sqlUser                String   @default("") @db.VarChar(100)
  sqlPassword            String   @default("") @db.VarChar(200)
  trustServerCertificate Boolean  @default(true)

  // Kestrel HTTPS
  kestrelUrl             String   @default("https://*:443") @db.VarChar(200)
  certPath               String   @default("certificate.pfx") @db.VarChar(500)
  certPassword           String   @default("") @db.VarChar(200)

  // Certificat auto-signé généré (optionnel)
  certPfxBase64          String?  @db.LongText                    // PFX en base64 (null = pas encore généré)
  certHostnames          String   @default("") @db.VarChar(1000)  // CSV des IPs/DNS couverts
  certValidFrom          DateTime?
  certValidUntil         DateTime?

  // WaveSoft EDI
  ediOutputFolder        String   @default("C:\\DATA_Wavesoft\\AutomateIE") @db.VarChar(500)
  ediSeparator           String   @default(";") @db.VarChar(5)

  // Sync settings
  batchSize              Int      @default(1000)
  timeoutSeconds         Int      @default(300)
  retryAttempts          Int      @default(3)
  histoPiece             Int      @default(-1)

  // Mot de passe admin mobile (protège le changement de base dans Préférences)
  // Vide = pas de protection. Propagé aux apps via le JWT de licence.
  mobileAdminPassword    String   @default("") @db.VarChar(100)

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  company                Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  licenses               License[]

  @@map("sync_service_deployments")
}

// ─── Instances SQL Server rattachées à une licence ────────────────────────
// Une licence couvre 1..N instances (cas multi-serveurs). Chaque instance
// regroupe les credentials SQL + ses bases. Le mobile envoie X-Instance = key.

model LicenseSqlInstance {
  id                     String   @id @default(uuid()) @db.VarChar(36)
  licenseId              String   @db.VarChar(36)

  key                    String   @db.VarChar(50)          // slug technique (header X-Instance, ex: SIEGE, FILIALE)
  label                  String   @default("") @db.VarChar(200) // libellé affiché côté mobile (ex: "Siège", "Filiale Lyon")
  isDefault              Boolean  @default(false)          // instance pré-sélectionnée après activation

  // Credentials SQL (null = hériter du Deployment)
  sqlHost                String?  @db.VarChar(200)
  sqlUser                String?  @db.VarChar(100)
  sqlPassword            String?  @db.VarChar(200)

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  license                License  @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  databases              LicenseDatabase[]

  @@unique([licenseId, key])
  @@map("license_sql_instances")
}

// ─── Bases WaveSoft rattachées à une instance ─────────────────────────────
// Chaque base est unique au sein d'une instance. Le mobile envoie X-Database = name.
// 2 bases peuvent porter le même nom si elles sont dans 2 instances différentes.

model LicenseDatabase {
  id                     String   @id @default(uuid()) @db.VarChar(36)
  instanceId             String   @db.VarChar(36)

  name                   String   @db.VarChar(100)    // ex: PROD (header X-Database, nom SQL réel)
  label                  String   @default("") @db.VarChar(200) // libellé affiché côté mobile
  isDefault              Boolean  @default(false)     // base pré-sélectionnée au sein de l'instance

  // Tircode "Clients divers" spécifique à cette base
  clientsDiversTircode   String   @default("") @db.VarChar(50)

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  instance               LicenseSqlInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@unique([instanceId, name])
  @@map("license_databases")
}

// ─── Alertes d'expiration envoyées ──────────────────────────────────────

model LicenseAlert {
  id        String   @id @default(uuid()) @db.VarChar(36)
  licenseId String   @db.VarChar(36)
  daysTag   Int      // 45, 30, 15, 7 ou 0 (jour d'expiration)
  sentAt    DateTime @default(now())
  sentTo    String   @db.VarChar(200) // email destinataire

  license   License  @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  @@unique([licenseId, daysTag])
  @@map("license_alerts")
}

// ─── Configuration branding & infos légales (remplace companyInfo.js) ───────

model CompanyConfig {
  id                    String  @id @default(uuid()) @db.VarChar(36)
  companyId             String  @unique @db.VarChar(36)
  logoUrl               String  @default("") @db.VarChar(500)
  subtitle              String  @default("") @db.VarChar(200)
  email                 String  @default("") @db.VarChar(200)
  phone                 String  @default("") @db.VarChar(50)
  website               String  @default("") @db.VarChar(200)
  addressStreet         String  @default("") @db.VarChar(200)
  addressZipCode        String  @default("") @db.VarChar(10)
  addressCity           String  @default("") @db.VarChar(100)
  addressCountry        String  @default("France") @db.VarChar(50)
  siret                 String  @default("") @db.VarChar(20)
  tva                   String  @default("") @db.VarChar(30)
  capital               String  @default("") @db.VarChar(50)
  rcs                   String  @default("") @db.VarChar(100)
  ape                   String  @default("") @db.VarChar(10)
  paymentTerms          String  @default("") @db.VarChar(200)
  quotationValidityDays Int     @default(30)
  tvaRate               Float   @default(0.20)
  termsAndConditions    String  @default("") @db.Text

  company               Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_configs")
}

// ─── Appareils activés par licence ──────────────────────────────────────────

model DeviceActivation {
  id            String   @id @default(uuid()) @db.VarChar(36)
  licenseId     String   @db.VarChar(36)
  deviceId      String   @db.VarChar(100)
  deviceName    String   @default("") @db.VarChar(200)
  platform      String   @default("android") @db.VarChar(20)
  activatedAt   DateTime @default(now())
  lastHeartbeat DateTime @default(now())
  isActive      Boolean  @default(true)

  license       License  @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  @@unique([licenseId, deviceId])
  @@map("device_activations")
}

// ─── Logs d'usage ───────────────────────────────────────────────────────────

model UsageLog {
  id        String   @id @default(uuid()) @db.VarChar(36)
  licenseId String   @db.VarChar(36)
  deviceId  String   @default("") @db.VarChar(100)
  eventType String   @db.VarChar(50)
  eventData Json
  createdAt DateTime @default(now())

  license   License  @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  @@map("usage_logs")
}

// ─── Utilisateurs admin (dashboard) ─────────────────────────────────────────

model AdminUser {
  id           String   @id @default(uuid()) @db.VarChar(36)
  email        String   @unique @db.VarChar(200)
  passwordHash String   @db.VarChar(200)
  role         String   @default("admin") @db.VarChar(20)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("admin_users")
}

// ─── Demandes de contact (site vitrine) ─────────────────────────────────────

model ContactRequest {
  id        String   @id @default(uuid()) @db.VarChar(36)
  name      String   @db.VarChar(200)
  email     String   @db.VarChar(200)
  company   String   @default("") @db.VarChar(200)
  phone     String   @default("") @db.VarChar(50)
  message   String   @db.Text
  type      String   @default("info") @db.VarChar(20)
  status    String   @default("new") @db.VarChar(20)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contact_requests")
}
